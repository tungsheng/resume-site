{
  "name": "resume-site",
  "type": "module",
  "private": true,
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "preview": "astro preview",
    "build": "astro build && bun run build:pdf",
    "build:pdf": "bun run scripts/build-resume-pdf.ts",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit",
    "test:integration": "RUN_INTEGRATION_TESTS=1 bun test tests/integration",
    "test:all": "bun test tests/unit tests/integration",
    "typecheck": "astro sync && tsc --noEmit",
    "check": "bun run typecheck && bun run test:unit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "puppeteer-core": "^24.35.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  }
}
