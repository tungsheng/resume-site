---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceMatrix from "../../components/EvidenceMatrix.astro";
import { DECISIONS_PATH } from "../../../src/features/site/content";
import {
  getDecisionDomains,
  getDecisionExperimentTitle,
  getDecisionProjectSummary,
  getDecisionRecordsByProject,
} from "../../../src/features/site/decision-content";
import { experimentDetailPath } from "../../../src/features/site/experiment-catalog-content";
import { projectContent } from "../../../src/features/site/project-content";
import {
  getProjectById,
  projectPortfolioContent,
  type ProjectId,
} from "../../../src/features/site/projects-content";

// Faithful port of DecisionProjectRoute (/decisions/<projectId>) from
// src/features/decisions/page.tsx. Design frozen (ADR-0003 §5); typed data
// reused unchanged (ADR-0003 §9). TwoMetricEvidenceMatrix re-rendered via the
// new EvidenceMatrix.astro component. Last detail-route family.
export function getStaticPaths() {
  return projectPortfolioContent.projects.map((p) => ({ params: { project: p.id } }));
}

const projectId = Astro.params.project as ProjectId;
const project = getProjectById(projectId);
const summary = getDecisionProjectSummary(projectId);
const decisions = getDecisionRecordsByProject(projectId);
const domains = getDecisionDomains(projectId);

// Mirrors statusColor()/getStatusCounts() in the React source.
const STATUS_ORDER = ["Supported", "Measured", "Caveated", "Partial", "Rejected", "Blocked"];
const STATUS_COLOR: Record<string, string> = {
  Supported: "#00AB66",
  Measured: "#006B40",
  Caveated: "#743914",
  Partial: "#276f89",
  Rejected: "#d32f2f",
  Blocked: "#743914",
};
const statusCounts = STATUS_ORDER.map((status) => ({
  status,
  count: decisions.filter((d) => d.status === status).length,
})).filter((item) => item.count > 0);
const statusChipStyle = (status: string) => {
  const c = STATUS_COLOR[status] ?? "#465750";
  return `color:${c};border-color:color-mix(in srgb, ${c} 35%, transparent);background-color:color-mix(in srgb, ${c} 5.5%, transparent)`;
};

const eyebrow = "text-[0.74rem] font-semibold uppercase tracking-[0.1em] text-go-green-dark";
const h2 = "h-section-title";
const card = "rounded-lg border border-surface-border bg-paper p-3.5";
const accent = "rounded-lg border border-go-green/20 bg-go-green/8 p-3";
const statusChip = "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-bold";
const expBtn = "inline-flex min-h-8 items-center rounded border border-ink/25 px-2.5 py-1 text-xs font-medium text-ink transition-colors hover:bg-ink/5";
const primaryBtn = "inline-flex min-h-10 items-center justify-center rounded px-4 py-2 text-sm font-medium bg-ink text-paper transition-opacity hover:opacity-90";
const outlinedBtn = "inline-flex min-h-10 items-center justify-center rounded px-4 py-2 text-sm font-medium border border-ink/25 text-ink transition-colors hover:bg-ink/5";
const textBtn = "inline-flex min-h-10 items-center px-2 text-sm font-medium text-ink hover:underline";

const evidenceVisuals = projectId === "gpu-inference-lab" ? projectContent.validation.evidenceVisuals : [];
---

<BaseLayout
  title={`${summary.title} | Tony Lee`}
  description={summary.lead}
  activeNav="decisions"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Decisions", href: DECISIONS_PATH },
    { label: project.title },
  ]}
>
  <!-- Header -->
  <section class="mb-[1.375rem] grid items-start gap-[0.85rem] md:mb-6 md:gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(21rem,0.52fr)]">
    <div class="flex max-w-[58rem] flex-col gap-2.5 md:gap-3">
      <h1 class="h-detail-title">{summary.title}</h1>
      <p class="text-base leading-relaxed text-muted">{summary.lead}</p>
      <div class="flex flex-wrap items-center gap-3">
        <a href={summary.experimentsPath} class={primaryBtn}>View experiments</a>
        <a href={project.path} class={outlinedBtn}>Project overview</a>
        <a href={project.repositoryUrl} target="_blank" rel="noreferrer" class={textBtn}>GitHub</a>
      </div>
    </div>
    <div class={`grid grid-cols-2 gap-2 sm:grid-cols-3 ${accent}`} aria-label="Decision status dashboard">
      {
        statusCounts.map((item) => (
          <div class="grid content-start gap-0.5 rounded-md border border-surface-border bg-paper px-3 py-2">
            <p class={eyebrow}>{item.status}</p>
            <p class="text-[1.18rem] font-semibold">{item.count}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Decision matrix -->
  <section class="mb-7 grid gap-5 md:mb-[2.125rem] md:gap-6">
    <div class="grid max-w-[52rem] gap-1">
      <p class={eyebrow}>Decision matrix</p>
      <h2 class={h2}>{summary.sectionTitle}</h2>
      <p class="text-base leading-relaxed text-muted">
        Each decision is grouped by domain and links back to the experiments that produced the evidence.
      </p>
    </div>

    <div class="grid gap-4">
      {
        domains.map((domain) => {
          const domainDecisions = decisions.filter((d) => d.domain === domain);
          return (
            <section class={`grid gap-3 ${card}`}>
              <div class="grid gap-0.5">
                <p class={eyebrow}>Domain</p>
                <h3 class="font-display text-[1.18rem] font-semibold">{domain}</h3>
              </div>
              <div class="grid gap-3 lg:grid-cols-2">
                {domainDecisions.map((decision) => (
                  <section class="grid content-start gap-2.5 rounded-lg border border-surface-border bg-paper p-3.5">
                    <div class="flex flex-wrap items-start justify-between gap-2">
                      <div class="grid min-w-0 gap-0.5">
                        <p class={eyebrow}>{decision.domain}</p>
                        <h4 class="text-[1.05rem] font-semibold" style="overflow-wrap:anywhere">{decision.title}</h4>
                      </div>
                      <span class={statusChip} style={statusChipStyle(decision.status)}>{decision.status}</span>
                    </div>
                    <p class="text-sm font-bold">{decision.call}</p>
                    <p class="text-sm leading-relaxed text-muted">{decision.evidence}</p>
                    {decision.nextEvidence && (
                      <div class="rounded-md border border-surface-border border-l-[3px] border-l-warning-warm/60 bg-paper p-2.5">
                        <p class="text-xs font-bold text-muted">Next evidence</p>
                        <p class="text-sm leading-relaxed text-muted">{decision.nextEvidence}</p>
                      </div>
                    )}
                    {decision.experimentSlugs.length > 0 && (
                      <div class="flex flex-wrap gap-2" aria-label={`${decision.title} related experiments`}>
                        {decision.experimentSlugs.map((slug) => (
                          <a href={experimentDetailPath(slug)} class={expBtn}>{getDecisionExperimentTitle(slug)}</a>
                        ))}
                      </div>
                    )}
                  </section>
                ))}
              </div>
            </section>
          );
        })
      }
    </div>
  </section>

  <!-- GPU evidence visuals -->
  {
    evidenceVisuals.length > 0 && (
      <section class="grid gap-4">
        <div class="grid max-w-[52rem] gap-1">
          <p class={eyebrow}>Evidence visuals</p>
          <h2 class={h2}>Decision evidence visuals</h2>
          <p class="text-base leading-relaxed text-muted">
            Local visuals recreate the key proof points without depending on the lab repository at runtime.
          </p>
        </div>
        <div class="grid gap-4 lg:grid-cols-2">
          {evidenceVisuals.map((visual) => (
            <EvidenceMatrix
              title={visual.title}
              takeaway={visual.takeaway}
              sourceLabel={visual.sourceLabel}
              columns={visual.columns}
              rows={visual.rows}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
