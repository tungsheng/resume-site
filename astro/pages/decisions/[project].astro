---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceMatrix from "../../components/EvidenceMatrix.astro";
import {
  DECISIONS_PATH,
  getDecisionDomains,
  getDecisionExperimentTitle,
  getDecisionProjectSummary,
  getDecisionRecordsByProject,
  experimentDetailPath,
  projectContent,
  getProjectById,
  projectPortfolioContent,
  type ProjectId,
} from "@site";

// Swiss-minimal redesign — decision project record (/decisions/<projectId>),
// ADR-0005 / #21. Status dashboard becomes a hairline count grid; the decision
// matrix becomes domain-grouped hairline cells with tone-colored status labels.
// Presentation only — typed data reused unchanged.
export function getStaticPaths() {
  return projectPortfolioContent.projects.map((p) => ({ params: { project: p.id } }));
}

const projectId = Astro.params.project as ProjectId;
const project = getProjectById(projectId);
const summary = getDecisionProjectSummary(projectId);
const decisions = getDecisionRecordsByProject(projectId);
const domains = getDecisionDomains(projectId);

const STATUS_ORDER = ["Supported", "Measured", "Caveated", "Partial", "Rejected", "Blocked"];
const STATUS_COLOR: Record<string, string> = {
  Supported: "#006b40",
  Measured: "#006b40",
  Caveated: "#8a4413",
  Partial: "#276f89",
  Rejected: "#b3261e",
  Blocked: "#8a4413",
};
const statusCounts = STATUS_ORDER.map((status) => ({
  status,
  count: decisions.filter((d) => d.status === status).length,
})).filter((item) => item.count > 0);
const statusLabel = (status: string) => `color:${STATUS_COLOR[status] ?? "#5c6670"}`;

const grid = "grid gap-px border border-surface-border bg-surface-border";
const cell = "bg-paper p-4 grid content-start";
const warnBlock = "border-l-2 border-l-warning-warm/70 pl-3";

const evidenceVisuals = projectId === "gpu-inference-lab" ? projectContent.validation.evidenceVisuals : [];
---

<BaseLayout
  title={`${summary.title} | Tony Lee`}
  description={summary.lead}
  activeNav="decisions"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Decisions", href: DECISIONS_PATH },
    { label: project.title },
  ]}
>
  <!-- Header -->
  <section class="grid gap-6 border-b border-surface-border pb-9 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(16rem,0.46fr)] lg:gap-12">
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.04] tracking-[-0.02em] text-[clamp(1.9rem,4.5vw,3rem)]">{summary.title}</h1>
      <p class="text-[1.02rem] leading-relaxed text-muted md:text-[1.12rem]">{summary.lead}</p>
      <div class="mt-1 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href={summary.experimentsPath} class="cta group text-go-green-dark hover:text-ink">
          View experiments
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href={project.path} class="cta group text-ink hover:text-go-green-dark">
          Project overview
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href={project.repositoryUrl} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">GitHub</a>
      </div>
    </div>
    <div class={`${grid} grid-cols-2 sm:grid-cols-3 lg:self-end`} aria-label="Decision status dashboard">
      {
        statusCounts.map((item) => (
          <div class={`${cell} gap-1`}>
            <p class="eyebrow" style={statusLabel(item.status)}>{item.status}</p>
            <p class="text-[1.3rem] font-semibold tabular text-ink">{item.count}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Decision matrix -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2">Decision matrix</p>
    <h2 class="h-section-title">{summary.sectionTitle}</h2>
    <p class="mt-2.5 max-w-[52rem] text-[0.97rem] leading-relaxed text-muted">
      Each decision is grouped by domain and links back to the experiments that produced the evidence.
    </p>

    <div class="mt-6 grid gap-10">
      {
        domains.map((domain) => {
          const domainDecisions = decisions.filter((d) => d.domain === domain);
          return (
            <section>
              <div class="mb-3 flex items-baseline gap-3 border-b border-ink/15 pb-2">
                <span class="eyebrow">Domain</span>
                <h3 class="text-[1.15rem] font-semibold tracking-[-0.01em] text-ink">{domain}</h3>
              </div>
              <div class={`${grid} lg:grid-cols-2`}>
                {domainDecisions.map((decision) => (
                  <section class={`${cell} gap-2.5`}>
                    <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                      <h4 class="text-[1.05rem] font-semibold text-ink" style="overflow-wrap:anywhere">{decision.title}</h4>
                      <span class="eyebrow shrink-0" style={statusLabel(decision.status)}>{decision.status}</span>
                    </div>
                    <p class="text-[0.92rem] font-bold text-ink">{decision.call}</p>
                    <p class="text-[0.92rem] leading-relaxed text-muted">{decision.evidence}</p>
                    {decision.nextEvidence && (
                      <div class={warnBlock}>
                        <p class="eyebrow mb-0.5" style="color:#8a4413">Next evidence</p>
                        <p class="text-[0.9rem] leading-relaxed text-muted">{decision.nextEvidence}</p>
                      </div>
                    )}
                    {decision.experimentSlugs.length > 0 && (
                      <div class="mt-0.5 flex flex-wrap gap-x-5 gap-y-1.5" aria-label={`${decision.title} related experiments`}>
                        {decision.experimentSlugs.map((slug) => (
                          <a href={experimentDetailPath(slug)} class="cta text-ink hover:text-go-green-dark">
                            {getDecisionExperimentTitle(slug)}
                          </a>
                        ))}
                      </div>
                    )}
                  </section>
                ))}
              </div>
            </section>
          );
        })
      }
    </div>
  </section>

  <!-- GPU evidence visuals -->
  {
    evidenceVisuals.length > 0 && (
      <section class="mt-12 md:mt-16">
        <p class="eyebrow mb-2">Evidence visuals</p>
        <h2 class="h-section-title">Decision evidence visuals</h2>
        <p class="mt-2.5 max-w-[52rem] text-[0.97rem] leading-relaxed text-muted">
          Local visuals recreate the key proof points without depending on the lab repository at runtime.
        </p>
        <div class="mt-5 grid gap-px border border-surface-border bg-surface-border lg:grid-cols-2">
          {evidenceVisuals.map((visual) => (
            <EvidenceMatrix
              title={visual.title}
              takeaway={visual.takeaway}
              sourceLabel={visual.sourceLabel}
              columns={visual.columns}
              rows={visual.rows}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
