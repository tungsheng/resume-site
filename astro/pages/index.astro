---
import BaseLayout from "../layouts/BaseLayout.astro";
import { selectLatest } from "../content/blog-schema";
import { getVisiblePosts } from "../content/posts";

// Swiss-minimal redesign tracer (ADR-0005 / PRD #20): flush-left grid-led hero
// and a hairline-ruled "Latest writing" list with monospace system detailing.
// Presentation only — the data (getVisiblePosts/selectLatest) is unchanged.
const PAGE_TITLE = "Tony Lee | Staff Software Engineer (Full-Stack)";
const HOME_ROLE = "Staff Software Engineer (Full-Stack) · Transitioning to ML Infrastructure";
const HOME_LEDE =
  "I build full-stack products and lead architecture across cross-regional teams. I'm now transitioning into ML infrastructure through self-directed, reproducible GPU-serving labs — AWS, EKS, Terraform, and vLLM, measured honestly including the negative results.";

const ctaLink =
  "group inline-flex items-center gap-2 font-mono text-[0.75rem] font-semibold uppercase tracking-[0.12em] transition-colors";

// "Latest writing" (#10): baked into the static HTML at build time — the newest
// Published Posts, no runtime fetch. Drafts are filtered out by getVisiblePosts.
const LATEST_COUNT = 3;
const latest = selectLatest(await getVisiblePosts(), LATEST_COUNT);
// ISO date (YYYY-MM-DD), tabular monospace — the techie metadata treatment.
// Dates are authored as UTC calendar days, so slice the ISO string directly.
const isoDate = (date: Date) => date.toISOString().slice(0, 10);
---

<BaseLayout title={PAGE_TITLE} description={HOME_LEDE} activeNav="home">
  <!-- Hero: flush-left, no card; whitespace + big Inter type do the work. -->
  <section class="border-b border-surface-border pb-12 pt-4 md:pb-20 md:pt-10">
    <p class="eyebrow mb-6">{HOME_ROLE}</p>
    <h1
      class="max-w-4xl text-balance font-semibold leading-[0.95] tracking-[-0.02em] text-[clamp(3rem,9vw,6.5rem)]"
    >
      Tony Lee
    </h1>
    <p class="mt-7 max-w-2xl text-[1.05rem] leading-relaxed text-muted md:mt-9 md:text-[1.2rem]">
      {HOME_LEDE}
    </p>
    <div class="mt-9 flex flex-wrap gap-x-8 gap-y-3 md:mt-12">
      <a href="/projects" class={ctaLink + " text-go-green-dark hover:text-ink"}>
        View projects <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
      <a href="/experiments" class={ctaLink + " text-ink hover:text-go-green-dark"}>
        View experiments <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
      <a href="/resume" class={ctaLink + " text-ink hover:text-go-green-dark"}>
        View resume <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </section>

  {
    latest.length > 0 && (
      <section class="pt-12 md:pt-16" aria-labelledby="latest-writing">
        <div class="mb-2 flex items-baseline justify-between gap-4 border-b border-surface-border pb-4">
          <h2
            id="latest-writing"
            class="text-[1.4rem] font-semibold tracking-[-0.01em] md:text-[1.7rem]"
          >
            Latest writing
          </h2>
          <a href="/blog" class={ctaLink + " shrink-0 text-go-green-dark hover:text-ink"}>
            Read the blog <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
        <ul>
          {latest.map((post, i) => (
            <li class="border-b border-surface-border">
              <a
                href={`/blog/${post.id}`}
                class="group grid grid-cols-[auto_1fr] items-baseline gap-x-4 py-5 sm:grid-cols-[2.5rem_1fr_auto] sm:gap-x-8"
              >
                <span class="section-index text-[0.72rem] tabular">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="min-w-0">
                  <span class="eyebrow mb-1.5 block">{post.data.category}</span>
                  <h3 class="text-[1.15rem] font-semibold leading-snug text-ink transition-colors group-hover:text-go-green-dark md:text-[1.4rem]">
                    {post.data.title}
                  </h3>
                </div>
                <time
                  datetime={isoDate(post.data.published)}
                  class="col-start-2 mt-2 font-mono text-[0.72rem] tabular text-muted sm:col-start-3 sm:mt-0 sm:text-right"
                >
                  {isoDate(post.data.published)}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
