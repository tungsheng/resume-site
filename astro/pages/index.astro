---
import BaseLayout from "../layouts/BaseLayout.astro";
import { selectLatest } from "../content/blog-schema";
import { isoDay } from "../content/post-list";
import { getVisiblePosts } from "../content/posts";

// Editorial redesign (#56): a typography-first hero in Newsreader + a hairline-
// ruled "Latest writing" list detailed in IBM Plex Mono. Presentation only — the
// data (getVisiblePosts/selectLatest) is unchanged.
const PAGE_TITLE = "Tony Lee | Staff Software Engineer (Full-Stack)";
const HOME_ROLE = "Staff Software Engineer (Full-Stack) · Transitioning to ML Inference";
// SEO description mirrors the visible lede (kept as one flat string for the meta).
const HOME_LEDE =
  "I build full-stack products and lead architecture across cross-regional teams. I'm now transitioning into ML inference engineering through self-directed, reproducible labs — vLLM GPU serving on AWS/EKS and CUDA/Triton kernel benchmarking, measured honestly, including the negative results.";

// Mono CTA link with an accent underline that resolves from 0.4 opacity to full
// on hover; pair with `group` + the arrow span for the nudge.
const ctaLink =
  "group inline-flex items-baseline gap-2 font-mono text-[0.84rem] text-go-green-dark border-b border-go-green/40 pb-[3px] transition-colors hover:border-go-green";

// "Latest writing" (#10): the newest Published Posts, baked into static HTML at
// build time. Drafts are filtered out by getVisiblePosts.
const LATEST_COUNT = 3;
const latest = selectLatest(await getVisiblePosts(), LATEST_COUNT);
---

<BaseLayout title={PAGE_TITLE} description={HOME_LEDE} activeNav="home">
  <!-- Hero -->
  <section class="pb-20 pt-14 md:pt-[72px]">
    <p class="font-mono text-[0.75rem] uppercase tracking-[0.14em] text-go-green-dark">
      {HOME_ROLE}
    </p>
    <h1
      class="mb-[34px] mt-5 max-w-[15ch] font-medium leading-[0.98] tracking-[-0.028em] text-[clamp(4rem,11vw,6.75rem)]"
    >
      Tony Lee
    </h1>
    <p class="max-w-[640px] text-[1.25rem] leading-[1.62] text-body">
      I build full-stack products and lead architecture across cross-regional teams. I'm now
      transitioning into ML inference engineering through self-directed, reproducible labs — vLLM
      GPU serving on AWS/EKS and CUDA/Triton kernel benchmarking, <em
        class="italic text-go-green-dark">measured honestly, including the negative results.</em
      >
    </p>
    <div class="mt-[38px] flex flex-wrap gap-x-[26px] gap-y-3">
      <a href="/work" class={ctaLink}>
        View work <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
      </a>
      <a href="/resume" class={ctaLink}>
        View resume <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </div>
  </section>

  {
    latest.length > 0 && (
      <section class="mt-[110px]" aria-labelledby="latest-writing">
        <div class="flex items-baseline justify-between gap-4 border-b border-surface-border pb-3">
          <h2
            id="latest-writing"
            class="font-mono text-[0.75rem] uppercase tracking-[0.14em] text-muted"
          >
            Latest writing
          </h2>
          <a
            href="/blog"
            class="group inline-flex items-baseline gap-2 shrink-0 font-mono text-[0.78rem] text-go-green-dark transition-colors hover:text-ink"
          >
            Read the blog{" "}
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
              &rarr;
            </span>
          </a>
        </div>
        <ul>
          {latest.map((post, i) => (
            <li class="border-b border-surface-border">
              <a
                href={`/blog/${post.id}`}
                class="group grid grid-cols-[2.5rem_1fr] items-baseline gap-x-4 py-[26px] text-ink transition-colors hover:text-go-green-dark sm:grid-cols-[4rem_1fr_auto] sm:gap-x-6"
              >
                <span class="font-mono text-[0.81rem] tabular text-faint">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="min-w-0">
                  <span class="font-mono text-[0.69rem] uppercase tracking-[0.1em] text-go-green-dark">
                    {post.data.category}
                  </span>
                  <h3 class="mt-1.5 font-medium leading-[1.25] text-[1.35rem] sm:text-[1.55rem]">
                    {post.data.title}
                  </h3>
                </div>
                <time
                  datetime={isoDay(post.data.published)}
                  class="col-start-2 mt-2 font-mono text-[0.75rem] tabular text-faint sm:col-start-3 sm:mt-0 sm:text-right"
                >
                  {isoDay(post.data.published)}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
