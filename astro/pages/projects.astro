---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projectPortfolioContent } from "@site";

// Swiss-minimal redesign — Projects index (ADR-0005 / PRD #20 rollout). Flush-
// left header with a hairline-ruled right-rail note, and projects as hairline-
// separated editorial blocks (mono meta rail + content) instead of shadowed
// cards. Presentation only — the typed data module is reused unchanged.
const PAGE_TITLE = "Projects | Tony Lee";
const { title, lede, summary, projects } = projectPortfolioContent;
---

<BaseLayout
  title={PAGE_TITLE}
  description={lede}
  activeNav="projects"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Projects" }]}
>
  <!-- Index header -->
  <section
    class="grid gap-6 border-b border-surface-border pb-10 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(17rem,0.5fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1
        class="text-balance font-semibold leading-[1.02] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]"
      >
        {title}
      </h1>
      <p class="text-[1.05rem] leading-relaxed text-muted md:text-[1.15rem]">{lede}</p>
    </div>
    <p class="border-l border-surface-border pl-4 text-sm leading-relaxed text-muted lg:self-end">
      {summary}
    </p>
  </section>

  <!-- Project blocks -->
  <section>
    {
      projects.map((project) => (
        <article class="grid gap-4 border-b border-surface-border py-9 md:grid-cols-[minmax(0,8rem)_minmax(0,1fr)] md:gap-10">
          <div class="flex flex-row flex-wrap gap-x-4 gap-y-1 md:flex-col md:gap-2">
            <span class="eyebrow">{project.layer}</span>
            <span
              class={
                "eyebrow " +
                (project.statusTone === "supported" ? "text-go-green-dark" : "text-support-cool")
              }
            >
              {project.status}
            </span>
            <span class="eyebrow text-faint">{project.experimentCount} experiments</span>
          </div>

          <div class="grid gap-3">
            <h2 class="text-[1.4rem] font-semibold leading-tight tracking-[-0.01em] md:text-[1.7rem]">
              <a href={project.path} class="transition-colors hover:text-go-green-dark">
                {project.title}
              </a>
            </h2>
            <p class="max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{project.summary}</p>
            <p class="text-[0.97rem] font-semibold text-ink">{project.result}</p>

            <ul class="mt-1 grid gap-2">
              {project.evidence.map((item) => (
                <li class="grid grid-cols-[0.9rem_minmax(0,1fr)] gap-2 text-[0.92rem] leading-normal text-muted">
                  <span class="font-mono text-go-green-dark" aria-hidden="true">
                    &mdash;
                  </span>
                  <span class="max-w-[44rem]">{item}</span>
                </li>
              ))}
            </ul>

            <div class="mt-3 flex flex-wrap items-center gap-x-7 gap-y-3">
              <a href={project.path} class="cta group text-go-green-dark hover:text-ink">
                View project
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                  &rarr;
                </span>
              </a>
              <a href={project.primaryAction.href} class="cta group text-ink hover:text-go-green-dark">
                {project.primaryAction.label}
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                  &rarr;
                </span>
              </a>
              <a
                href={project.repositoryUrl}
                target="_blank"
                rel="noreferrer"
                class="cta link-external text-ink hover:text-go-green-dark"
              >
                GitHub
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
