---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projectPortfolioContent } from "../../src/features/site/projects-content";

// Faithful port of the /projects index route (ProjectsIndexRoute in
// src/features/project/page.tsx). Design frozen (ADR-0003 §5); the typed data
// module is reused unchanged (ADR-0003 §9). The two project DETAIL routes
// (/projects/gpu-inference-lab, /projects/cuda-kernel-lab) are a separate slice.
const PAGE_TITLE = "Projects | Tony Lee";
const { title, lede, summary, projects } = projectPortfolioContent;

const chipBase =
  "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold";
const chipMuted = chipBase + " border-go-green/25 bg-go-green/[0.065] text-ink/70";
const chipDefault = chipBase + " border-go-green/30 bg-go-green/[0.075] text-ink";
const chipSuccess = chipBase + " border-go-green/30 bg-go-green/10 text-go-green-dark";
const chipInfo = chipBase + " border-support-cool/30 bg-support-cool/10 text-support-cool";

const primaryBtn =
  "inline-flex min-h-10 items-center justify-center rounded px-4 py-2 text-sm font-medium bg-ink text-paper transition-opacity hover:opacity-90";
const outlinedBtn =
  "inline-flex min-h-10 items-center justify-center rounded px-4 py-2 text-sm font-medium border border-ink/25 text-ink transition-colors hover:bg-ink/5";
const textBtn =
  "inline-flex min-h-10 items-center gap-1 px-2 text-sm font-medium text-ink hover:underline";
---

<BaseLayout
  title={PAGE_TITLE}
  description={lede}
  activeNav="projects"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Projects" }]}
>
  <section class="grid gap-8 md:gap-9">
    <!-- Index header -->
    <div class="grid items-start gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.52fr)]">
      <div class="flex max-w-[58rem] flex-col gap-3">
        <h1 class="font-display text-[2.42rem] font-semibold leading-tight text-balance">
          {title}
        </h1>
        <p class="text-base leading-relaxed text-muted">{lede}</p>
      </div>
      <div class="rounded-lg border border-go-green/20 bg-go-green/8 p-5">
        <p class="text-sm leading-relaxed text-muted">{summary}</p>
      </div>
    </div>

    <!-- Project cards -->
    <div class="grid gap-5 lg:grid-cols-2">
      {
        projects.map((project) => (
          <section class="flex h-full flex-col gap-4 rounded-lg border border-surface-border bg-paper p-6">
            <div class="flex flex-wrap items-center gap-2">
              <span class={chipMuted}>{project.layer}</span>
              <span class={project.statusTone === "supported" ? chipSuccess : chipInfo}>
                {project.status}
              </span>
              <span class={chipDefault}>{project.experimentCount} experiments</span>
            </div>

            <div class="grid gap-2">
              <h2 class="font-display text-[1.85rem] font-semibold leading-snug">
                {project.title}
              </h2>
              <p class="text-sm leading-relaxed text-muted">{project.summary}</p>
              <p class="text-sm font-semibold">{project.result}</p>
            </div>

            <ul class="grid gap-2">
              {project.evidence.map((item) => (
                <li class="grid grid-cols-[0.55rem_minmax(0,1fr)] items-baseline gap-2 text-[0.92rem] leading-normal text-muted">
                  <span
                    class="mt-1 inline-block h-[0.45rem] w-[0.45rem] rounded-full bg-go-green/90"
                    aria-hidden="true"
                  />
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="mt-auto flex flex-wrap items-center gap-3 pt-1">
              <a href={project.path} class={primaryBtn}>
                View project
              </a>
              <a href={project.primaryAction.href} class={outlinedBtn}>
                {project.primaryAction.label}
              </a>
              <a
                href={project.repositoryUrl}
                target="_blank"
                rel="noreferrer"
                class={textBtn}
              >
                GitHub
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
              </a>
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
