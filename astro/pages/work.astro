---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projectPortfolioContent, getDecisionRecordsByProject } from "@site";

// Work index (Plan A consolidation): /work lists the projects directly — no
// Projects/Experiments/Decisions switchboard. Editorial redesign (#57): each
// project is a two-column row — a giant serif index numeral beside the meta
// line, title, description, measured-result bullets, and links. Data unchanged.
const PAGE_TITLE = "Work | Tony Lee";
const LEDE =
  "Evidence-backed GPU systems work across serving infrastructure and kernel optimization. " +
  "Each project page carries the story, the architecture calls, and the measured runs behind them.";

const projects = projectPortfolioContent.projects.map((project) => ({
  ...project,
  decisionCount: getDecisionRecordsByProject(project.id).length,
}));
---

<BaseLayout
  title={PAGE_TITLE}
  description={LEDE}
  activeNav="work"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Work" }]}
>
  <!-- Header -->
  <section class="pb-16">
    <h1
      class="max-w-[620px] font-medium leading-[1.05] tracking-[-0.022em] text-[clamp(2.625rem,6vw,3.625rem)]"
    >
      Measured GPU systems work
    </h1>
    <p class="mt-[22px] max-w-[620px] text-[1.19rem] leading-[1.6] text-body">{LEDE}</p>
  </section>

  <!-- Project rows -->
  <section>
    {
      projects.map((project, i) => (
        <article
          class:list={[
            "grid grid-cols-1 items-start gap-x-6 gap-y-4 border-t border-surface-border pt-11 pb-12 sm:grid-cols-[110px_1fr]",
            i === projects.length - 1 && "border-b",
          ]}
        >
          <span class="font-normal leading-none text-[3.25rem] text-[#c9c7c3]">
            {String(i + 1).padStart(2, "0")}
          </span>

          <div class="flex flex-col gap-[14px]">
            <p class="font-mono text-[0.69rem] uppercase tracking-[0.12em] text-muted">
              {project.layer}
              <span class="text-faint">
                {" · "}
                {project.experimentCount} experiments · {project.decisionCount} decisions
              </span>
            </p>

            <h2 class="text-[2rem] font-medium leading-[1.1] tracking-[-0.015em]">
              <a href={project.path} class="transition-colors hover:text-go-green-dark">
                {project.title}
              </a>
            </h2>

            <p class="max-w-[44rem] text-[1.09rem] leading-[1.55] text-secondary">
              {project.summary}
            </p>

            <ul class="mt-1 grid gap-2">
              {project.evidence.map((item) => (
                <li class="grid grid-cols-[1rem_1fr] gap-x-2 font-mono text-[0.78rem] leading-[1.5] text-secondary">
                  <span class="text-go-green-dark" aria-hidden="true">
                    &mdash;
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="mt-2 flex flex-wrap items-center gap-x-6 gap-y-2">
              <a
                href={project.path}
                class="group inline-flex items-baseline gap-2 font-mono text-[0.78rem] text-go-green-dark transition-colors hover:text-ink"
              >
                View project
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                  &rarr;
                </span>
              </a>
              <a
                href={project.repositoryUrl}
                target="_blank"
                rel="noreferrer"
                class="font-mono text-[0.78rem] text-ink transition-colors hover:text-go-green-dark"
              >
                GitHub <span aria-hidden="true">&#8599;</span>
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
