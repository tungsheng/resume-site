---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  CUDA_KERNEL_DECISIONS_PATH,
  CUDA_KERNEL_EXPERIMENTS_PATH,
  cudaKernelProjectContent,
  getProjectById,
} from "@site";

// Swiss-minimal redesign — CUDA Kernel Lab project detail (ADR-0005 / #21).
// Panels/cards become hairline spec-sheet grids, rounded-pill chips become mono
// labels, tone chips become tone-colored mono labels, and filled buttons become
// .cta links. Presentation only — the typed data module is reused unchanged.
const content = cudaKernelProjectContent;
const project = getProjectById("cuda-kernel-lab");

const repo = content.repositoryUrl;
const reportLinks = [
  { label: "Strategy report", href: `${repo}/blob/main/experiments/reports/aws-ec2/2026-05-21-strategy-next.md` },
  { label: "Decode replay report", href: `${repo}/blob/main/experiments/reports/aws-ec2/2026-05-22-round12-kv-active-views.md` },
  { label: "H200 report", href: `${repo}/blob/main/experiments/reports/runpod/20260526-h200-persistent-waves-073234.md` },
  { label: "Profiler reports", href: `${repo}/tree/main/profiling/reports/2026-05-21-strategy-next` },
];

// Status tone -> text color, applied to a monospace label (no pill). Restrained
// but keeps the supported/measured/caveated semantics.
const TONE: Record<string, string> = {
  success: "#006b40",
  warning: "#8a4413",
  info: "#276f89",
  error: "#b3261e",
  neutral: "#5c6670",
};
const toneLabel = (tone = "neutral") => `color:${TONE[tone] ?? TONE.neutral}`;

// Hairline spec-sheet grid: 1px gaps over a border-colored bg with white cells.
const grid = "mt-5 grid gap-px border border-surface-border bg-surface-border";
const cell = "bg-paper p-4 grid content-start";
---

<BaseLayout
  title={`${content.title} | Tony Lee`}
  description={content.lede}
  activeNav="projects"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Work", href: "/work" },
    { label: "Projects", href: "/projects" },
    { label: content.title },
  ]}
>
  <!-- Detail header -->
  <section
    class="grid gap-6 border-b border-surface-border pb-9 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(15rem,0.44fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.04] tracking-[-0.02em] text-[clamp(1.9rem,4.5vw,3rem)]">
        {content.title}
      </h1>
      <p class="text-[1.02rem] leading-relaxed text-muted md:text-[1.12rem]">{content.lede}</p>
      <div class="mt-1 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href={CUDA_KERNEL_EXPERIMENTS_PATH} class="cta group text-go-green-dark hover:text-ink">
          View experiments
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href={CUDA_KERNEL_DECISIONS_PATH} class="cta group text-ink hover:text-go-green-dark">
          View decisions
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href={project.repositoryUrl} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
          GitHub
        </a>
      </div>
    </div>
    <div class="flex flex-col gap-3 border-l border-surface-border pl-5 lg:self-end">
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <span class="eyebrow">{project.layer}</span>
        <span class="eyebrow text-go-green-dark">{project.status}</span>
        <span class="eyebrow text-faint">{project.experimentCount} experiments</span>
      </div>
      <p class="text-[0.92rem] leading-relaxed text-muted">{project.result}</p>
    </div>
  </section>

  <!-- At a glance -->
  <section class="mt-12 md:mt-16">
    <h2 class="h-section-title">At a glance</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{content.overviewSummary}</p>
    <div class={`${grid} sm:grid-cols-2 lg:grid-cols-3`}>
      {
        content.overviewFacts.map((fact) => (
          <div class={`${cell} gap-1.5`}>
            <p class="eyebrow">{fact.label}</p>
            <p class="text-[1.05rem] font-semibold leading-snug text-ink">{fact.value}</p>
            <p class="text-[0.92rem] leading-relaxed text-muted">{fact.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Optimization loop -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2">Workflow</p>
    <h2 class="h-section-title">Optimization loop</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">
      Every kernel claim moves through the same loop: profile first, isolate the bottleneck, change
      only that path, then re-profile before calling it a win.
    </p>
    <div class={`${grid} md:grid-cols-2 min-[1536px]:grid-cols-4`}>
      {
        content.optimizationLoop.map((step) => (
          <div class={`${cell} gap-2`}>
            <span class="section-index text-[0.72rem] tabular">{step.step}</span>
            <p class="eyebrow">{step.title}</p>
            <p class="text-[0.92rem] leading-relaxed text-muted">{step.body}</p>
            <p class="mt-1 text-[0.92rem] font-semibold text-ink">{step.evidence}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Benchmark readout -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2">A10G/H200 evidence</p>
    <h2 class="h-section-title">Benchmark readout</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">
      The selected runs show where custom kernels are useful, where profiler counters explain the
      result, and where newer H200 matmul tuning remains measured but caveated.
    </p>
    <div class={`${grid} md:grid-cols-2 min-[1536px]:grid-cols-4`} aria-label="CUDA benchmark readout">
      {
        content.results.map((item) => (
          <div class={`${cell} grid-rows-[auto_minmax(0,1fr)_auto] gap-2`}>
            <p class="eyebrow">{item.title}</p>
            <div class="grid content-start gap-1">
              <p class="text-sm font-bold text-ink">{item.call}</p>
              <p class="text-[0.92rem] leading-relaxed text-muted">{item.proof}</p>
            </div>
            <span
              class="font-mono text-[0.7rem] font-semibold uppercase tracking-[0.1em]"
              style={toneLabel(item.tone)}
            >
              {item.statusLabel}
            </span>
          </div>
        ))
      }
    </div>
    <div class="mt-6 flex flex-wrap items-center gap-x-7 gap-y-3">
      <a href={CUDA_KERNEL_EXPERIMENTS_PATH} class="cta group text-go-green-dark hover:text-ink">
        Kernel experiments
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
      {
        reportLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
            {link.label}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
