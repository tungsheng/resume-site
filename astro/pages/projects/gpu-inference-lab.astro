---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommandCodeBlock from "../../components/CommandCodeBlock.astro";
import {
  EXPERIMENTS_PATH,
  GPU_INFERENCE_DECISIONS_PATH,
  GPU_INFERENCE_EXPERIMENTS_PATH,
  implementation,
  projectContent,
  getProjectById,
} from "@site";

// Swiss-minimal redesign — GPU Inference Lab project detail (ADR-0005 / #21).
// Panels become hairline spec-sheet grids, pills become sharp bordered tags with
// mono arrows, tone chips become tone-colored mono labels, buttons become .cta
// links. CommandCodeBlock (dark code panel) is kept as-is. Presentation only —
// the typed data modules are reused unchanged.
const project = getProjectById("gpu-inference-lab");
const c = projectContent;

const TONE: Record<string, string> = {
  success: "#006b40",
  warning: "#8a4413",
  info: "#276f89",
  error: "#b3261e",
  neutral: "#5c6670",
};
const toneLabel = (tone = "neutral") => `color:${TONE[tone] ?? TONE.neutral}`;

// Hairline spec-sheet grid: 1px gaps over a border-colored bg with white cells.
const grid = "mt-5 grid gap-px border border-surface-border bg-surface-border";
const cell = "bg-paper p-4 grid content-start";
// Workflow flow node: sharp bordered tag + mono arrows between nodes.
const tag =
  "inline-flex items-center gap-2 border border-surface-border px-3 py-1.5 text-[0.86rem] font-medium leading-snug text-ink";
const nodeBadge =
  "font-mono text-[0.64rem] uppercase tracking-[0.1em] text-go-green-dark hover:text-ink";
const arrow = "select-none font-mono text-go-green-dark/50";
---

<BaseLayout
  title={`${c.title} | Tony Lee`}
  description={c.lede}
  activeNav="projects"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects" },
    { label: c.title },
  ]}
>
  <!-- Detail header -->
  <section
    class="grid gap-6 border-b border-surface-border pb-9 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(15rem,0.44fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.04] tracking-[-0.02em] text-[clamp(1.9rem,4.5vw,3rem)]">
        {c.title}
      </h1>
      <p class="text-[1.02rem] leading-relaxed text-muted md:text-[1.12rem]">{c.lede}</p>
      <div class="mt-1 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href={GPU_INFERENCE_EXPERIMENTS_PATH} class="cta group text-go-green-dark hover:text-ink">
          View experiments
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href={GPU_INFERENCE_DECISIONS_PATH} class="cta group text-ink hover:text-go-green-dark">
          View decisions
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href={project.repositoryUrl} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
          GitHub
        </a>
      </div>
    </div>
    <div class="flex flex-col gap-3 border-l border-surface-border pl-5 lg:self-end">
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <span class="eyebrow">{project.layer}</span>
        <span class="eyebrow text-go-green-dark">{project.status}</span>
        <span class="eyebrow text-faint">{project.experimentCount} experiments</span>
      </div>
      <p class="text-[0.92rem] leading-relaxed text-muted">{project.result}</p>
    </div>
  </section>

  <!-- At a glance -->
  <section class="mt-12 md:mt-16">
    <h2 class="h-section-title">At a glance</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{c.overviewSummary}</p>
    <div class={`${grid} sm:grid-cols-2 lg:grid-cols-3`}>
      {
        c.overviewFacts.map((fact) => (
          <div class={`${cell} gap-1.5`}>
            <p class="eyebrow">{fact.label}</p>
            <p class="text-[1.05rem] font-semibold leading-snug text-ink">{fact.value}</p>
            <p class="text-[0.92rem] leading-relaxed text-muted">{fact.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Lab usage -->
  <section class="mt-12 md:mt-16">
    <h2 class="h-section-title">{c.usage.title}</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{c.usage.lead}</p>

    <!-- Workflows -->
    <div class={`${grid} lg:grid-cols-3`}>
      {
        c.usage.workflows.map((w) => (
          <div class={`${cell} gap-3`}>
            <div class="grid gap-1">
              <p class="eyebrow">Workflow</p>
              <p class="text-[1.05rem] font-semibold leading-snug text-ink">{w.title}</p>
              <p class="text-[0.92rem] leading-relaxed text-muted">{w.body}</p>
            </div>
            <div class="grid gap-2">
              <p class="text-[0.92rem] text-ink">{w.when}</p>
              <div class="flex flex-wrap gap-x-3 gap-y-1">
                {w.outputs.map((o) => <span class="eyebrow text-faint">{o}</span>)}
              </div>
            </div>
            <div class="grid gap-2">
              <CommandCodeBlock command={w.command} ariaLabel={`${w.title} command`} />
              <a href={w.href} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
                Source
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Default path quick start -->
    <div class="mt-8 border-t border-surface-border pt-8">
      <p class="eyebrow mb-2">{implementation.defaultPathTitle}</p>
      <p class="max-w-[52rem] text-[0.95rem] leading-relaxed text-muted">{implementation.defaultPathLead}</p>
      <div class={`${grid} md:grid-cols-3`}>
        {
          implementation.defaultPathSteps.map((step, i) => (
            <div class={`${cell} gap-3`}>
              <div class="flex items-baseline gap-2.5">
                <span class="section-index text-[0.72rem] tabular" aria-label={`Step ${i + 1}`}>
                  {String(i + 1).padStart(2, "0")}
                </span>
                <p class="text-[1.02rem] font-semibold leading-snug text-ink">{step.title}</p>
              </div>
              <CommandCodeBlock command={step.command} ariaLabel={`${step.title} command`} />
              <p class="text-[0.92rem] leading-relaxed text-muted">{step.body}</p>
            </div>
          ))
        }
      </div>

      <p class="eyebrow mb-2 mt-8">{implementation.verifyProofTitle}</p>
      <div class={`${grid} md:grid-cols-3`}>
        {
          implementation.verifyProofs.map((proof) => (
            <div class={`${cell} grid-cols-[1.1rem_minmax(0,1fr)] gap-2`}>
              <span class="font-mono text-go-green-dark" aria-hidden="true">&check;</span>
              <div>
                <p class="text-[0.92rem] font-semibold text-ink">{proof.title}</p>
                <p class="text-[0.92rem] leading-relaxed text-muted">{proof.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Decision contract concept -->
    <div class="mt-8 border-t border-surface-border pt-8">
      <p class="eyebrow mb-2">{c.usage.conceptTitle}</p>
      <p class="max-w-[52rem] text-[0.95rem] leading-relaxed text-muted">{c.usage.conceptLead}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-2" aria-label="Experiment concept flow">
        {
          c.usage.conceptSteps.map((step, i) => (
            <>
              {i > 0 && <span class={arrow} aria-hidden="true">&rarr;</span>}
              <span class={tag}>{step}</span>
            </>
          ))
        }
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-x-7 gap-y-3">
        {c.usage.links.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How serving scales -->
  <section class="mt-12 md:mt-16">
    <h2 class="h-section-title">{c.workflowSectionTitle}</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{c.workflowLead}</p>

    <!-- Foundation -->
    <div class="mt-6">
      <p class="eyebrow mb-2">{c.workflowFoundation.title}</p>
      <p class="max-w-[52rem] text-[0.92rem] leading-relaxed text-muted">{c.workflowFoundation.summary}</p>
      <div class="mt-3 flex flex-wrap gap-2" aria-label="Foundation workflow">
        {
          c.workflowFoundation.nodes.map((node) => (
            <span class={tag}>
              <span class="min-w-0">{node.label}</span>
              {"href" in node && node.href && (
                <a href={node.href} target="_blank" rel="noreferrer" class={nodeBadge}>
                  {("linkLabel" in node && node.linkLabel) || "Code"}
                </a>
              )}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Paths -->
    {
      c.workflowPaths.map((path) => (
        <div class="mt-6 border-t border-surface-border pt-6">
          <p class="text-[1.02rem] font-semibold text-ink">{path.title}</p>
          <p class="mt-1 max-w-[52rem] text-[0.92rem] leading-relaxed text-muted">{path.summary}</p>
          <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-2" aria-label={`${path.title} workflow`}>
            {path.nodes.map((node, i) => (
              <>
                {i > 0 && <span class={arrow} aria-hidden="true">&rarr;</span>}
                <span class={tag}>
                  <span class="min-w-0">{node.label}</span>
                  {"href" in node && node.href && (
                    <a href={node.href} target="_blank" rel="noreferrer" class={nodeBadge}>
                      {("linkLabel" in node && node.linkLabel) || "Code"}
                    </a>
                  )}
                </span>
              </>
            ))}
          </div>
        </div>
      ))
    }

    <!-- Rejoin -->
    <div class="mt-6 border-t border-surface-border pt-6">
      <p class="eyebrow mb-2">Rejoin point</p>
      <p class="max-w-[52rem] text-[0.92rem] leading-relaxed text-muted">{c.workflowRejoin.body}</p>
      <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-2" aria-label="Rejoin workflow">
        {
          c.workflowRejoin.nodes.map((node, i) => (
            <>
              {i > 0 && <span class={arrow} aria-hidden="true">&rarr;</span>}
              <span class={tag}>
                <span class="min-w-0">{node.label}</span>
                {"href" in node && node.href && (
                  <a href={node.href} target="_blank" rel="noreferrer" class={nodeBadge}>
                    {("linkLabel" in node && node.linkLabel) || "Code"}
                  </a>
                )}
              </span>
            </>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Evidence -->
  <section class="mt-12 md:mt-16">
    <h2 class="h-section-title">{c.evidence.title}</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{c.evidence.lead}</p>
    <div class={`${grid} md:grid-cols-2 xl:grid-cols-4`} aria-label="Architecture readout">
      {
        c.evidence.items.map((item) => (
          <div class={`${cell} grid-rows-[auto_minmax(0,1fr)_auto] gap-2`}>
            <p class="eyebrow">{item.title}</p>
            <div class="grid content-start gap-1.5">
              <p class="text-sm font-bold text-ink">{item.call}</p>
              <p class="text-[0.92rem] leading-relaxed text-muted">{item.proof}</p>
            </div>
            <span
              class="font-mono text-[0.7rem] font-semibold uppercase tracking-[0.1em]"
              style={toneLabel(item.tone)}
            >
              {item.statusLabel}
            </span>
          </div>
        ))
      }
    </div>
    <div class="mt-6 flex flex-wrap items-center gap-x-7 gap-y-3">
      <a href={GPU_INFERENCE_DECISIONS_PATH} class="cta group text-go-green-dark hover:text-ink">
        Architecture decisions
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
      <a href={EXPERIMENTS_PATH} class="cta group text-ink hover:text-go-green-dark">
        Experiment catalog
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
      {c.evidence.links.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
          {link.label}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
