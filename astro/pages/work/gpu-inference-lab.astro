---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DecisionMatrix from "../../components/DecisionMatrix.astro";
import EvidenceMatrix from "../../components/EvidenceMatrix.astro";
import ExperimentTable from "../../components/ExperimentTable.astro";
import { getDecisionProjectSummary, getDecisionRecordsByProject, projectContent, getProjectById } from "@site";

// Consolidated project case study, redundancy-cut edition: hero (result first,
// platform facts in the sidebar) → decisions → one evidence visual →
// experiment table. The former "At a glance" and "Architecture readout"
// sections restated the decision records and are gone; the lede stays as the
// meta description. Typed data modules unchanged — display selects from them.
const project = getProjectById("gpu-inference-lab");
const c = projectContent;
const decisionSummary = getDecisionProjectSummary("gpu-inference-lab");
const decisionCount = getDecisionRecordsByProject("gpu-inference-lab").length;

// Sidebar facts: the platform facts that appear nowhere else on the page.
const HERO_FACT_LABELS = ["Platform", "Scale signal", "Baseline"];
const heroFacts = c.overviewFacts.filter((f) => HERO_FACT_LABELS.includes(f.label));

// One visual earns its keep: queue attribution is the only table whose numbers
// are not already quoted in a decision row.
const queueVisual = c.validation.evidenceVisuals.find((v) => v.title === "Queue attribution");
---

<BaseLayout
  title={`${c.title} | Tony Lee`}
  description={c.lede}
  activeNav="work"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Work", href: "/work" },
    { label: c.title },
  ]}
>
  <!-- Hero: the result, then straight to the record. -->
  <section
    class="grid gap-6 border-b border-surface-border pb-9 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(15rem,0.44fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.04] tracking-[-0.02em] text-[clamp(1.9rem,4.5vw,3rem)]">
        {c.title}
      </h1>
      <p class="text-[1.02rem] font-semibold leading-relaxed text-ink md:text-[1.12rem]">
        {project.result}
      </p>
      <div class="mt-1 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href="#decisions" class="cta group text-go-green-dark hover:text-ink">
          Decisions
          <span aria-hidden="true" class="transition-transform group-hover:translate-y-0.5">&darr;</span>
        </a>
        <a href="#experiments" class="cta group text-ink hover:text-go-green-dark">
          Experiments
          <span aria-hidden="true" class="transition-transform group-hover:translate-y-0.5">&darr;</span>
        </a>
        <a href={project.repositoryUrl} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
          GitHub
        </a>
      </div>
    </div>
    <dl class="grid content-end gap-2 border-l border-surface-border pl-5 text-[0.85rem]">
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <span class="eyebrow">{project.layer}</span>
        <span class="eyebrow text-faint">{project.experimentCount} experiments &middot; {decisionCount} decisions</span>
      </div>
      {
        heroFacts.map((fact) => (
          <div class="grid grid-cols-[6.5rem_minmax(0,1fr)] gap-2">
            <dt class="eyebrow">{fact.label}</dt>
            <dd class="font-semibold text-ink">{fact.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Decisions: the results section. -->
  <DecisionMatrix projectId="gpu-inference-lab" sectionTitle={decisionSummary.sectionTitle} />

  <!-- One evidence visual: latency attribution, not restated in any decision row. -->
  {
    queueVisual && (
      <section class="mt-12 md:mt-16">
        <p class="eyebrow mb-2">Evidence visual</p>
        <h2 class="h-section-title">Where the latency lives</h2>
        <div class="mt-5 grid border border-surface-border bg-surface-border lg:max-w-[52rem]">
          <EvidenceMatrix
            title={queueVisual.title}
            takeaway={queueVisual.takeaway}
            sourceLabel={queueVisual.sourceLabel}
            columns={queueVisual.columns}
            rows={queueVisual.rows}
          />
        </div>
      </section>
    )
  }

  <!-- Experiments -->
  <ExperimentTable projectId="gpu-inference-lab" />
</BaseLayout>
