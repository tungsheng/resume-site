---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import { toPostListItems } from "../../content/post-list";
import { getVisiblePosts } from "../../content/posts";

// Swiss-minimal redesign — Blog index at /blog (ADR-0005 / #21). The
// hairline-ruled post list lives in PostList.astro, shared with the
// /blog/tags/[tag] pages (#48). Visibility by Status (ADR-0003 §8).
const posts = toPostListItems(await getVisiblePosts());

const LEDE =
  "Engineering writing on inference serving, scheduler behavior, and GPU kernel paths.";
---

<BaseLayout
  title="Blog | Tony Lee"
  description={LEDE}
  activeNav="blog"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Blog" }]}
>
  <section class="border-b border-surface-border pb-10 md:pb-12">
    <h1 class="text-balance font-semibold leading-[1.02] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]">
      Blog
    </h1>
    <p class="mt-4 max-w-[46rem] text-[1.05rem] leading-relaxed text-muted md:text-[1.15rem]">{LEDE}</p>
  </section>

  {
    /* Search island (#49 / ADR-0009 decision 3, sanctioned by ADR-0008: search
       is impossible without client JS). The entire UI — input included — is
       injected by PagefindUI at runtime, so with JS disabled nothing dead
       renders and the page stays the fully-functional static list + tag pages.
       PROD-only: the /pagefind/ assets are emitted by `pagefind --site dist`
       after the build and don't exist under `astro dev` (preview via
       dist-preview). */
    import.meta.env.PROD && (
      <>
        <div id="search" class="mt-8" aria-label="Search posts"></div>
        <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
        <script is:inline defer src="/pagefind/pagefind-ui.js"></script>
        {/* External file, not an Astro-processed script: the deployed CSP
            (public/_headers) is script-src 'self' with no 'unsafe-inline',
            and Astro inlines bundled scripts this small back into the page. */}
        <script is:inline defer src="/js/search-init.js"></script>
      </>
    )
  }

  {
    posts.length === 0 ? (
      <p class="mt-10 text-muted">No posts published yet.</p>
    ) : (
      <PostList posts={posts} />
    )
  }
</BaseLayout>

<style is:global>
  /* Theme Pagefind's default UI to the Swiss-minimal tokens (ADR-0005). */
  #search {
    --pagefind-ui-primary: var(--color-go-green-dark);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--color-surface-border);
    --pagefind-ui-tag: var(--color-surface-border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-font: inherit;
  }
</style>
