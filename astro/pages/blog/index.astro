---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readingTimeMinutes, sortByPublishedDesc } from "../../content/blog-schema";
import { getVisiblePosts } from "../../content/posts";

// Blog index at /blog — every visible Post, newest-first. Visibility by Status
// (ADR-0003 §8): Published-only in prod, all statuses in dev.
const posts = sortByPublishedDesc(await getVisiblePosts()).map((post) => ({
  slug: post.id,
  data: post.data,
  minutes: readingTimeMinutes(post.body ?? ""),
  dateLabel: post.data.published.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }),
}));

const LEDE =
  "Engineering writing on inference serving, scheduler behavior, and GPU kernel paths.";

const eyebrow = "text-[0.74rem] font-semibold uppercase tracking-[0.1em] text-go-green-dark";
const chipBase = "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold";
const chipMuted = chipBase + " border-go-green/25 bg-go-green/[0.065] text-ink/70";
---

<BaseLayout
  title="Blog | Tony Lee"
  description={LEDE}
  activeNav="blog"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Blog" }]}
>
  <section class="grid gap-8 md:gap-9">
    <div class="flex max-w-[58rem] flex-col gap-3">
      <h1 class="font-display text-[2.42rem] font-semibold leading-tight text-balance">Blog</h1>
      <p class="text-base leading-relaxed text-muted">{LEDE}</p>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-muted">No posts published yet.</p>
      ) : (
        <div class="grid gap-5">
          {posts.map((post) => (
            <article class="grid gap-3 rounded-lg border border-surface-border bg-paper p-6">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <span class={eyebrow}>{post.data.category}</span>
                <span class="text-sm text-muted">
                  {post.dateLabel} &middot; {post.minutes} min read
                </span>
              </div>
              <h2 class="font-display text-[1.6rem] font-semibold leading-snug">
                <a href={`/blog/${post.slug}`} class="hover:underline">{post.data.title}</a>
              </h2>
              <p class="max-w-[52rem] text-sm leading-relaxed text-muted">{post.data.summary}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag) => <span class={chipMuted}>{tag}</span>)}
                </div>
              )}
            </article>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
