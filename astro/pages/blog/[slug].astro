---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isPostVisible, readingTimeMinutes } from "../../content/blog-schema";

// Prerender a Post at /blog/<slug>. Visibility by Status (ADR-0003 §8): in a
// production build only Published Posts get a page; `astro dev` renders all
// statuses for preview.
export async function getStaticPaths() {
  const posts = await getCollection("blog", (post) =>
    isPostVisible(post.data.status, import.meta.env.PROD),
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const minutes = readingTimeMinutes(post.body ?? "");
const dateLabel = post.data.published.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<BaseLayout
  title={`${post.data.title} | Tony Lee`}
  description={post.data.summary}
  activeNav="blog"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: post.data.title },
  ]}
>
  <article class="mx-auto max-w-[44rem]">
    <p class="text-[0.74rem] font-semibold uppercase tracking-[0.1em] text-go-green-dark">
      {post.data.category}
    </p>
    <h1 class="mt-2 font-display text-[2.6rem] font-semibold leading-tight text-balance">
      {post.data.title}
    </h1>
    <p class="mt-3 text-sm text-muted">{dateLabel} &middot; {minutes} min read</p>
    <div class="post-body mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  /* Minimal prose styling for the tracer (rich blocks land in #6). Shiki styles
     the code blocks (.astro-code) inline; we only add spacing/scroll here. */
  .post-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
  }
  .post-body :global(> * + *) {
    margin-top: 1.15rem;
  }
  .post-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    line-height: 1.2;
    margin-top: 2.25rem;
  }
  .post-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.25;
    margin-top: 1.75rem;
  }
  .post-body :global(a) {
    color: var(--color-go-green-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.4rem;
  }
  .post-body :global(ul) { list-style: disc; }
  .post-body :global(ol) { list-style: decimal; }
  .post-body :global(li + li) { margin-top: 0.4rem; }
  .post-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: color-mix(in srgb, var(--color-ink) 6%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
  }
  .post-body :global(pre) {
    overflow-x: auto;
    padding: 1rem 1.15rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-surface-border);
  }
  .post-body :global(blockquote) {
    border-left: 3px solid color-mix(in srgb, var(--color-go-green) 50%, transparent);
    padding-left: 1rem;
    color: var(--color-muted);
  }
</style>
