---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  isPostVisible,
  readingTimeMinutes,
  selectTocHeadings,
  shouldShowToc,
} from "../../content/blog-schema";
import { resolveRelatedLinks } from "../../content/related-links";

// Prerender a Post at /blog/<slug>. Visibility by Status (ADR-0003 §8): in a
// production build only Published Posts get a page; `astro dev` renders all
// statuses for preview.
export async function getStaticPaths() {
  const posts = await getCollection("blog", (post) =>
    isPostVisible(post.data.status, import.meta.env.PROD),
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTimeMinutes(post.body ?? "");

// Dates are authored as plain calendar days — format in UTC to avoid an
// off-by-one from the local timezone.
const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });
const dateLabel = formatDate(post.data.published);

// "Updated" surfaces only when meaningfully later than the publish date (#7).
const updated = post.data.updated;
const updatedLabel =
  updated && updated.getTime() > post.data.published.getTime() ? formatDate(updated) : null;

// Auto-TOC from H2/H3 headings; shown only past the threshold (#7).
const toc = selectTocHeadings(headings);
const showToc = shouldShowToc(headings);

// Optional related Project/Experiment/Decision links; empty for standalone Posts.
const relatedLinks = resolveRelatedLinks(post.data.related);
---

<BaseLayout
  title={`${post.data.title} | Tony Lee`}
  description={post.data.summary}
  activeNav="blog"
  ogType="article"
  image={post.data.cover}
  publishedTime={post.data.published}
  modifiedTime={updatedLabel ? updated : undefined}
  tags={post.data.tags}
  section={post.data.category}
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: post.data.title },
  ]}
>
  <article class="mx-auto max-w-[44rem]">
    <p class="text-[0.74rem] font-semibold uppercase tracking-[0.1em] text-go-green-dark">
      {post.data.category}
    </p>
    <h1 class="mt-2 font-display text-[2.6rem] font-semibold leading-tight text-balance">
      {post.data.title}
    </h1>
    <p class="mt-3 text-sm text-muted">
      {dateLabel} &middot; {minutes} min read
      {updatedLabel && <Fragment> &middot; Updated {updatedLabel}</Fragment>}
    </p>

    {
      showToc && (
        <nav class="post-toc" aria-label="Table of contents">
          <p class="post-toc-title">On this page</p>
          <ul>
            {toc.map((heading) => (
              <li class={heading.depth === 3 ? "post-toc-sub" : undefined}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="post-body mt-8">
      <Content />
    </div>

    {
      relatedLinks.length > 0 && (
        <aside class="post-related" aria-label="Related work">
          <h2 class="post-related-title">Related</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li>
                <span class="post-related-kind">{link.kind}</span>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
</BaseLayout>

<style>
  /* Metadata surfaces (#7): auto-TOC + related links. These are authored in the
     component (not injected by <Content />), so Astro's scoped styles apply
     directly — no :global needed. Anchor jumps use scroll-behavior:smooth from
     global.css, so the TOC is zero-JS. */
  .post-toc {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-surface-border);
    border-radius: 0.5rem;
    background: var(--color-paper);
  }
  .post-toc-title {
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }
  .post-toc ul {
    margin-top: 0.6rem;
  }
  .post-toc li {
    line-height: 1.5;
  }
  .post-toc li + li {
    margin-top: 0.3rem;
  }
  .post-toc-sub {
    padding-left: 1rem;
  }
  .post-toc a {
    color: var(--color-go-green-dark);
    text-decoration: none;
  }
  .post-toc a:hover {
    text-decoration: underline;
  }

  .post-related {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-surface-border);
  }
  .post-related-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
  }
  .post-related ul {
    margin-top: 0.8rem;
  }
  .post-related li {
    display: flex;
    gap: 0.7rem;
    align-items: baseline;
  }
  .post-related li + li {
    margin-top: 0.5rem;
  }
  .post-related-kind {
    flex-shrink: 0;
    min-width: 5.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-support-cool);
  }
  .post-related a {
    color: var(--color-go-green-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Minimal prose styling for the tracer (rich blocks land in #6). Shiki styles
     the code blocks (.astro-code) inline; we only add spacing/scroll here. */
  .post-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
  }
  .post-body :global(> * + *) {
    margin-top: 1.15rem;
  }
  .post-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    line-height: 1.2;
    margin-top: 2.25rem;
  }
  .post-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.25;
    margin-top: 1.75rem;
  }
  .post-body :global(a) {
    color: var(--color-go-green-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.4rem;
  }
  .post-body :global(ul) { list-style: disc; }
  .post-body :global(ol) { list-style: decimal; }
  .post-body :global(li + li) { margin-top: 0.4rem; }
  .post-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: color-mix(in srgb, var(--color-ink) 6%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
  }
  .post-body :global(pre) {
    overflow-x: auto;
    padding: 1rem 1.15rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-surface-border);
  }
  .post-body :global(blockquote) {
    border-left: 3px solid color-mix(in srgb, var(--color-go-green) 50%, transparent);
    padding-left: 1rem;
    color: var(--color-muted);
  }

  /* Admonition callouts (#6): remark-admonitions emits
     <div class="callout callout-note|callout-warning"> with a .callout-title.
     Two tones reuse the site's accent / warning tokens. */
  .post-body :global(.callout) {
    margin-top: 1.6rem;
    padding: 0.9rem 1.15rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-surface-border);
    border-left-width: 4px;
  }
  .post-body :global(.callout > * + *) {
    margin-top: 0.6rem;
  }
  .post-body :global(.callout-title) {
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .post-body :global(.callout-note) {
    background: color-mix(in srgb, var(--color-accent-soft) 55%, transparent);
    border-left-color: var(--color-go-green);
  }
  .post-body :global(.callout-note .callout-title) {
    color: var(--color-go-green-dark);
  }
  .post-body :global(.callout-warning) {
    background: color-mix(in srgb, var(--color-warning-soft) 55%, transparent);
    border-left-color: var(--color-warning-warm);
  }
  .post-body :global(.callout-warning .callout-title) {
    color: var(--color-warning-warm);
  }

  /* GFM tables (#6): GFM is on by default — this just styles the output. */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    display: block;
    overflow-x: auto;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--color-surface-border);
    padding: 0.5rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  .post-body :global(thead th) {
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
    font-weight: 600;
  }

  /* Self-hosted images (#6): rehype-blog-images adds loading/decoding and wraps
     a lone image as <figure class="post-figure">. Cap width to avoid overflow
     and layout shift. */
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
  .post-body :global(.post-figure) {
    margin-top: 1.6rem;
    text-align: center;
  }
  .post-body :global(.post-figure figcaption) {
    margin-top: 0.5rem;
    font-size: 0.84rem;
    color: var(--color-muted);
  }
</style>
