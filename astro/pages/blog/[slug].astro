---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  isPostVisible,
  readingTimeMinutes,
  selectTocHeadings,
  shouldShowToc,
} from "../../content/blog-schema";
import { resolveRelatedLinks } from "../../content/related-links";
import { isRegisteredTag, tagLabel, tagPath } from "../../content/tag-registry";
import { hasMathDelimiter } from "../../markdown/detect-math";

// Prerender a Post at /blog/<slug>. Visibility by Status (ADR-0003 §8): in a
// production build only Published Posts get a page; `astro dev` renders all
// statuses for preview.
export async function getStaticPaths() {
  const posts = await getCollection("blog", (post) =>
    isPostVisible(post.data.status, import.meta.env.PROD),
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTimeMinutes(post.body ?? "");

// Link the KaTeX stylesheet only when this Post's source carries math (#33 /
// ADR-0006). Scanning the raw body pre-render keeps the link in lockstep with
// what the math plugin renders — no frontmatter flag to forget.
const mathStylesheet = hasMathDelimiter(post.body ?? "");

// Dates are authored as plain calendar days — ISO (YYYY-MM-DD) for the techie
// tabular meta line; slice the UTC ISO string directly to avoid an off-by-one.
const isoDate = (date: Date) => date.toISOString().slice(0, 10);
const dateLabel = isoDate(post.data.published);

// "Updated" surfaces only when meaningfully later than the publish date (#7).
const updated = post.data.updated;
const updatedLabel =
  updated && updated.getTime() > post.data.published.getTime() ? isoDate(updated) : null;

// Auto-TOC from H2/H3 headings; shown only past the threshold (#7).
const toc = selectTocHeadings(headings);
const showToc = shouldShowToc(headings);

// Optional related Project/Experiment/Decision links; empty for standalone Posts.
const relatedLinks = resolveRelatedLinks(post.data.related);
---

<BaseLayout
  title={`${post.data.title} | Tony Lee`}
  description={post.data.summary}
  activeNav="blog"
  ogType="article"
  image={post.data.cover}
  publishedTime={post.data.published}
  modifiedTime={updatedLabel ? updated : undefined}
  tags={post.data.tags}
  section={post.data.category}
  mathStylesheet={mathStylesheet}
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: post.data.title },
  ]}
>
  <article class="mx-auto max-w-[44rem]">
    <p class="eyebrow text-go-green-dark">{post.data.category}</p>
    <h1 class="mt-3 text-balance font-semibold leading-[1.05] tracking-[-0.02em] text-[clamp(2rem,5vw,3rem)]">
      {post.data.title}
    </h1>
    <p class="mt-4 font-mono text-[0.72rem] uppercase tracking-[0.08em] tabular text-muted">
      {dateLabel} &middot; {minutes} min read
      {updatedLabel && <Fragment> &middot; Updated {updatedLabel}</Fragment>}
    </p>

    {
      showToc && (
        <nav class="post-toc" aria-label="Table of contents">
          <p class="post-toc-title">On this page</p>
          <ul>
            {toc.map((heading) => (
              <li class={heading.depth === 3 ? "post-toc-sub" : undefined}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="post-body mt-8">
      <Content />
    </div>

    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-10 flex flex-wrap gap-x-4 gap-y-2" aria-label="Tags">
          {post.data.tags.filter(isRegisteredTag).map((tag) => (
            <a href={tagPath(tag)} class="eyebrow transition-colors hover:text-go-green-dark">
              {tagLabel(tag)}
            </a>
          ))}
        </div>
      )
    }

    {
      relatedLinks.length > 0 && (
        <aside class="post-related" aria-label="Related work">
          <h2 class="post-related-title">Related</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li>
                <span class="post-related-kind">{link.kind}</span>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
</BaseLayout>

<style>
  /* Swiss-minimal post styling (ADR-0005 / #21). The <Content/> markup is
     unchanged (the ADR-0004 Sätteri transforms still emit .callout / .post-figure
     / tables); only the CSS is restyled — hairline rules, mono labels, sharp
     corners. TOC + related are authored here, so scoped styles apply directly.
     Anchor jumps use scroll-behavior:smooth from global.css (zero-JS). */
  .post-toc {
    margin-top: 2rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .post-toc-title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
  }
  .post-toc ul {
    margin-top: 0.7rem;
  }
  .post-toc li {
    line-height: 1.5;
  }
  .post-toc li + li {
    margin-top: 0.35rem;
  }
  .post-toc-sub {
    padding-left: 1rem;
  }
  .post-toc a {
    color: var(--color-go-green-dark);
    text-decoration: none;
  }
  .post-toc a:hover {
    color: var(--color-ink);
  }

  .post-related {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-surface-border);
  }
  .post-related-title {
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }
  .post-related ul {
    margin-top: 1rem;
  }
  .post-related li {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    border-top: 1px solid var(--color-rule);
    padding-top: 0.6rem;
  }
  .post-related li:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .post-related li + li {
    margin-top: 0.6rem;
  }
  .post-related-kind {
    flex-shrink: 0;
    min-width: 6rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }
  .post-related a {
    color: var(--color-go-green-dark);
    text-decoration: none;
  }
  .post-related a:hover {
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Prose: Inter body on the light canvas. */
  .post-body {
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--color-ink);
  }
  .post-body :global(> * + *) {
    margin-top: 1.15rem;
  }
  .post-body :global(h2) {
    font-weight: 600;
    font-size: 1.6rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
  }
  .post-body :global(h3) {
    font-weight: 600;
    font-size: 1.25rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-top: 1.9rem;
  }
  .post-body :global(a) {
    color: var(--color-go-green-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.4rem;
  }
  .post-body :global(ul) { list-style: disc; }
  .post-body :global(ol) { list-style: decimal; }
  .post-body :global(li + li) { margin-top: 0.4rem; }
  .post-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: color-mix(in srgb, var(--color-ink) 6%, transparent);
    padding: 0.1em 0.35em;
  }
  .post-body :global(pre) {
    overflow-x: auto;
    padding: 1rem 1.15rem;
    border: 1px solid var(--color-surface-border);
  }

  /* Admonition callouts (#6 / ADR-0004): flat hairline-left blocks with a mono
     uppercase title — no rounding, faint tone tint. */
  .post-body :global(.callout) {
    margin-top: 1.6rem;
    padding: 0.85rem 1.1rem;
    border-left: 3px solid var(--color-surface-border);
  }
  .post-body :global(.callout > * + *) {
    margin-top: 0.55rem;
  }
  .post-body :global(.callout-title) {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .post-body :global(.callout-note) {
    background: color-mix(in srgb, var(--color-accent-soft) 40%, transparent);
    border-left-color: var(--color-go-green);
  }
  .post-body :global(.callout-note .callout-title) {
    color: var(--color-go-green-dark);
  }
  .post-body :global(.callout-warning) {
    background: color-mix(in srgb, var(--color-warning-soft) 40%, transparent);
    border-left-color: var(--color-warning-warm);
  }
  .post-body :global(.callout-warning .callout-title) {
    color: var(--color-warning-warm);
  }

  /* GFM tables (#6): Swiss horizontal-rule table with mono column headers. */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border-bottom: 1px solid var(--color-surface-border);
    padding: 0.55rem 0.75rem 0.55rem 0;
    text-align: left;
    vertical-align: top;
  }
  .post-body :global(thead th) {
    border-bottom: 2px solid color-mix(in srgb, var(--color-ink) 30%, transparent);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  /* Self-hosted images (#6): rehype/hast transform wraps a lone image as
     <figure class="post-figure">. Sharp corners; cap width to avoid overflow. */
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
  }
  .post-body :global(.post-figure) {
    margin-top: 1.6rem;
  }
  .post-body :global(.post-figure figcaption) {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
</style>
