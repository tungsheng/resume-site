---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildResumeViewModel } from "../../src/features/resume/view-model";
import { publicResumeData } from "../../src/features/resume/data";

// Swiss-minimal redesign — Resume web page (ADR-0005 / #21), last web slice.
// Flush-left header + hairline-left contact rail; sections as mono labels over
// hairline rules, entries as hairline-separated blocks with mono-dashed
// highlights and mono tabular date ranges. Zero JS: the PDF download is a plain
// link to the build-time /resume.pdf. Presentation only — data/view-model reused.
const data = publicResumeData;
const view = buildResumeViewModel(data);
const { name, badges, contacts } = data.header;

const linkedinHref = contacts.linkedin
  ? contacts.linkedin.startsWith("http")
    ? contacts.linkedin
    : `https://linkedin.com/in/${contacts.linkedin}`
  : null;

const sectionLabel =
  "border-b border-surface-border pb-2.5 font-mono text-[0.76rem] font-semibold uppercase tracking-[0.14em] text-ink";
const entry = "border-b border-surface-border py-5 first:pt-0 last:border-b-0";
const subtitle = "text-[1.02rem] font-semibold text-ink";
const dateMeta = "shrink-0 font-mono text-[0.72rem] uppercase tracking-[0.08em] tabular text-faint";
---

<BaseLayout
  title={`${name} - Resume`}
  description={`Resume of ${name} — ${badges.join(" • ")}`}
  activeNav="resume"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Resume" }]}
>
  <!-- Header -->
  <section class="grid gap-6 border-b border-surface-border pb-9 md:pb-10 md:grid-cols-[minmax(0,1fr)_minmax(15rem,0.42fr)] md:gap-12">
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.02] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]">
        {name}
      </h1>
      {
        badges.length > 0 && (
          <div class="flex flex-wrap gap-x-5 gap-y-1.5">
            {badges.map((badge) => (
              <span class="eyebrow text-go-green-dark">{badge}</span>
            ))}
          </div>
        )
      }
      <div class="mt-1 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href="/resume.pdf" download class="cta group text-go-green-dark hover:text-ink">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Download PDF
        </a>
        <a href="/projects" class="cta group text-ink hover:text-go-green-dark">
          View projects
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
        <a href="/experiments" class="cta group text-ink hover:text-go-green-dark">
          View experiments
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
      </div>
    </div>

    {
      (contacts.email || linkedinHref) && (
        <address class="flex flex-col gap-2 border-l border-surface-border pl-5 not-italic md:self-center">
          <span class="eyebrow mb-0.5">Contact</span>
          {contacts.email && (
            <a
              href={`mailto:${contacts.email}`}
              class="font-mono text-[0.82rem] text-muted transition-colors hover:text-ink"
              style="overflow-wrap:anywhere"
            >
              {contacts.email}
            </a>
          )}
          {linkedinHref && (
            <a
              href={linkedinHref}
              target="_blank"
              rel="noreferrer"
              class="link-external font-mono text-[0.82rem] text-muted transition-colors hover:text-ink"
              style="overflow-wrap:anywhere"
            >
              {`linkedin.com/in/${contacts.linkedin}`}
            </a>
          )}
        </address>
      )
    }
  </section>

  <!-- Web resume view -->
  <div class="mt-12 grid items-start gap-x-12 gap-y-10 md:mt-14 md:grid-cols-[minmax(0,1.6fr)_minmax(260px,0.85fr)]" aria-label="Web resume view">
    <!-- Left column -->
    <div class="grid gap-10">
      {
        view.summary && (
          <section>
            <h2 class={sectionLabel}>Professional Summary</h2>
            <p class="mt-4 max-w-[46rem] leading-relaxed text-muted">{view.summary}</p>
          </section>
        )
      }

      {
        view.projects.length > 0 && (
          <section>
            <h2 class={sectionLabel}>{view.projectsTitle}</h2>
            <div class="mt-1">
              {view.projects.map((project) => (
                <div class={entry}>
                  <p class={subtitle}>{project.title}</p>
                  {project.highlights.length > 0 && (
                    <ul class="mt-3 grid gap-2">
                      {project.highlights.map((item) => (
                        <li class="grid grid-cols-[0.9rem_minmax(0,1fr)] gap-2 text-[0.92rem] leading-relaxed text-muted">
                          <span class="font-mono text-go-green-dark" aria-hidden="true">&mdash;</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </section>
        )
      }

      {
        view.experience.length > 0 && (
          <section>
            <h2 class={sectionLabel}>Experience</h2>
            <div class="mt-1">
              {view.experience.map((exp) => (
                <div class={entry}>
                  <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline">
                    <div>
                      <p class={subtitle}>{exp.title}</p>
                      <p class="text-[0.92rem] text-muted">{exp.company}</p>
                    </div>
                    <p class={dateMeta}>{exp.dateRange}</p>
                  </div>
                  {exp.highlights.length > 0 && (
                    <ul class="mt-3.5 grid gap-2">
                      {exp.highlights.map((item) => (
                        <li class="grid grid-cols-[0.9rem_minmax(0,1fr)] gap-2 text-[0.92rem] leading-relaxed text-muted">
                          <span class="font-mono text-go-green-dark" aria-hidden="true">&mdash;</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </section>
        )
      }
    </div>

    <!-- Right column -->
    <div class="grid gap-10">
      {
        view.skills.length > 0 && (
          <section>
            <h2 class={sectionLabel}>Skills</h2>
            <div class="mt-1">
              {view.skills.map((skill) => (
                <div class="border-b border-surface-border py-3.5 first:pt-0 last:border-b-0">
                  <p class="text-[0.95rem] font-semibold text-ink">{skill.categoryLabel}</p>
                  <p class="mt-1 text-[0.9rem] leading-relaxed text-muted">{skill.itemsText}</p>
                </div>
              ))}
            </div>
          </section>
        )
      }

      {
        view.education.length > 0 && (
          <section>
            <h2 class={sectionLabel}>Education</h2>
            <div class="mt-1">
              {view.education.map((edu) => (
                <div class={entry}>
                  <p class={subtitle}>{edu.degree}</p>
                  <p class="text-[0.92rem] text-muted">{edu.school}</p>
                  <p class={`mt-1 ${dateMeta}`}>{edu.dateRange}</p>
                </div>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </div>
</BaseLayout>
