---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildResumeViewModel, publicResumeData } from "@resume";

// Editorial redesign (#59): single 780px column. Stacked header (kicker, name,
// contact row with a bordered Download-PDF button), then mono-labelled sections
// on hairline rules. Zero JS: the PDF download is a plain link to the build-time
// /resume.pdf. Presentation only — the data + view-model are reused unchanged.
const data = publicResumeData;
const view = buildResumeViewModel(data);
const { name, badges, contacts } = data.header;

const linkedinHref = contacts.linkedin
  ? contacts.linkedin.startsWith("http")
    ? contacts.linkedin
    : `https://linkedin.com/in/${contacts.linkedin}`
  : null;

// The summary closes on an accent-italic clause (design). Split it off the tail
// so the lede reads plain and the clause carries the emphasis; falls back to the
// whole string if the phrase ever changes.
const SUMMARY_CLAUSE = "measured honestly, negative results included.";
const clauseAt = view.summary.lastIndexOf(SUMMARY_CLAUSE);
const summaryHead = clauseAt >= 0 ? view.summary.slice(0, clauseAt) : view.summary;
const summaryClause = clauseAt >= 0 ? view.summary.slice(clauseAt) : "";

// Project titles embed their stack in parens ("Lab Name (stack)"); render the
// name as the serif title and the parenthetical as an inline mono tag.
function splitTitle(title: string): { name: string; tag: string } {
  const m = title.match(/^(.*?)\s*\(([^)]+)\)\s*$/);
  return m ? { name: m[1], tag: m[2] } : { name: title, tag: "" };
}

const sectionLabel =
  "border-b border-surface-border pb-3 font-mono text-[0.75rem] font-medium uppercase tracking-[0.14em] text-go-green-dark";
const contactLink =
  "font-mono text-[0.78rem] text-go-green-dark border-b border-go-green/40 pb-[3px] transition-colors hover:border-go-green";
---

<BaseLayout
  title={`${name} - Resume`}
  description={`Resume of ${name} — ${badges.join(" • ")}`}
  activeNav="resume"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Resume" }]}
>
  <!-- Header -->
  <section>
    {
      badges.length > 0 && (
        <p class="mb-[18px] font-mono text-[0.75rem] uppercase tracking-[0.14em] text-go-green-dark">
          {badges.join(" · ")}
        </p>
      )
    }
    <h1 class="font-medium leading-[1.05] tracking-[-0.022em] text-[clamp(2.625rem,6vw,3.625rem)]">
      {name}
    </h1>
    <div class="mt-[30px] flex flex-wrap items-baseline gap-x-[26px] gap-y-3">
      <a
        href="/resume.pdf"
        download
        class="rounded-[2px] border border-go-green px-4 py-[9px] font-mono text-[0.78rem] text-go-green-dark transition-colors hover:bg-go-green hover:text-paper"
      >
        Download PDF
      </a>
      {
        contacts.email && (
          <a href={`mailto:${contacts.email}`} class={contactLink}>
            {contacts.email}
          </a>
        )
      }
      {
        linkedinHref && (
          <a href={linkedinHref} target="_blank" rel="noreferrer" class={contactLink}>
            LinkedIn <span aria-hidden="true">&rarr;</span>
          </a>
        )
      }
    </div>
  </section>

  <!-- Professional Summary -->
  {
    view.summary && (
      <section class="mt-16">
        <h2 class={sectionLabel}>Professional Summary</h2>
        <p class="mt-6 text-[1.125rem] leading-[1.65] text-body">
          {summaryHead}
          {summaryClause && <em class="italic text-go-green-dark">{summaryClause}</em>}
        </p>
      </section>
    )
  }

  <!-- Work Experience -->
  {
    view.experience.length > 0 && (
      <section class="mt-14">
        <h2 class={sectionLabel}>Work Experience</h2>
        <div class="mt-2">
          {view.experience.map((exp) => (
            <div class="border-b border-surface-border py-7 last:border-b-0">
              <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline">
                <h3 class="text-[1.5rem] font-medium leading-tight tracking-[-0.01em]">{exp.title}</h3>
                <p class="shrink-0 font-mono text-[0.75rem] tabular text-faint">{exp.dateRange}</p>
              </div>
              <p class="mb-4 mt-1.5 font-mono text-[0.78rem] text-muted">{exp.company}</p>
              {exp.highlights.length > 0 && (
                <ul class="grid gap-[9px]">
                  {exp.highlights.map((item) => (
                    <li class="grid grid-cols-[18px_1fr] text-[1.03rem] leading-[1.5] text-body">
                      <span class="font-mono text-go-green-dark" aria-hidden="true">
                        &mdash;
                      </span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- ML Inference — Self-Directed -->
  {
    view.projects.length > 0 && (
      <section class="mt-8">
        <h2 class={sectionLabel}>{view.projectsTitle}</h2>
        {view.projectsNote && (
          <p class="mt-5 text-[1.06rem] italic leading-[1.6] text-secondary">{view.projectsNote}</p>
        )}
        <div class="mt-2">
          {view.projects.map((project) => {
            const { name: projName, tag } = splitTitle(project.title);
            return (
              <div class="border-b border-surface-border py-[26px] last:border-b-0">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <h3 class="text-[1.375rem] font-medium leading-tight tracking-[-0.01em]">
                    {projName}
                  </h3>
                  {tag && (
                    <span class="font-mono text-[0.72rem] uppercase tracking-[0.06em] text-faint">
                      {tag}
                    </span>
                  )}
                </div>
                {project.highlights.length > 0 && (
                  <ul class="mt-3.5 grid gap-[9px]">
                    {project.highlights.map((item) => (
                      <li class="grid grid-cols-[18px_1fr] text-[1.03rem] leading-[1.5] text-body">
                        <span class="font-mono text-go-green-dark" aria-hidden="true">
                          &mdash;
                        </span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- Skills -->
  {
    view.skills.length > 0 && (
      <section class="mt-8">
        <h2 class={sectionLabel}>Skills</h2>
        <dl class="mt-6 grid gap-x-6 gap-y-3 sm:grid-cols-[200px_1fr]">
          {view.skills.map((skill) => (
            <>
              <dt class="font-mono text-[0.75rem] uppercase tracking-[0.06em] text-muted">
                {skill.categoryLabel}
              </dt>
              <dd class="text-[1rem] leading-[1.7] text-body">
                {skill.itemsText.replaceAll(" • ", " · ")}
              </dd>
            </>
          ))}
        </dl>
      </section>
    )
  }

  <!-- Education -->
  {
    view.education.length > 0 && (
      <section class="mt-14">
        <h2 class={sectionLabel}>Education</h2>
        <div class="mt-2">
          {view.education.map((edu) => (
            <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 border-b border-surface-border py-[22px] last:border-b-0">
              <div>
                <h3 class="text-[1.25rem] font-medium leading-tight">{edu.degree}</h3>
                <p class="mt-0.5 text-[0.97rem] text-secondary">{edu.school}</p>
              </div>
              <p class="shrink-0 font-mono text-[0.75rem] tabular text-faint">{edu.dateRange}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
