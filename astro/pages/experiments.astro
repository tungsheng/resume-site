---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  EXPERIMENTS_PATH,
  experimentCatalogContent,
  decisionProjectPath,
  getProjectById,
  projectPortfolioContent,
} from "@site";

// Swiss-minimal redesign — Experiments index (ADR-0005 / #21). Flush-left header
// with a mono facts strip + hairline right-rail note; per-project hairline
// editorial blocks. Presentation only — typed data modules reused unchanged.
const PAGE_TITLE = "Experiments | Tony Lee";
const LEDE =
  "Project-linked catalogs that turn GPU serving and kernel questions into evidence-backed decisions.";
const SUPPORT =
  "Choose a project to browse its experiment table. Detail routes stay available for individual run shape, evidence, and commands.";

const { experiments } = experimentCatalogContent;
const countTone = (tone: string) =>
  experiments.filter((e) => e.readiness.primary.tone === tone).length;
const projectCount = new Set(experiments.map((e) => e.projectId)).size;
const facts = [
  `${experiments.length} experiments`,
  `${projectCount} projects`,
  "Run-ready",
  `${countTone("supported")} supported`,
  `${countTone("selected")} selected`,
  `${countTone("rejected")} rejected`,
  `${countTone("pending")} pending`,
  `${countTone("blocked")} blocked`,
];

const cards = projectPortfolioContent.projects.map((p) => {
  const project = getProjectById(p.id);
  const projectExperiments = experiments.filter((e) => e.projectId === p.id);
  const focusAreas = new Set(projectExperiments.map((e) => e.category)).size;
  return { project, experimentCount: projectExperiments.length, focusAreas };
});
---

<BaseLayout
  title={PAGE_TITLE}
  description={LEDE}
  activeNav="experiments"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Work", href: "/work" }, { label: "Experiments" }]}
>
  <!-- Index header -->
  <section
    class="grid gap-6 border-b border-surface-border pb-10 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(17rem,0.5fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.02] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]">
        Experiments
      </h1>
      <p class="text-[1.05rem] leading-relaxed text-muted md:text-[1.15rem]">{LEDE}</p>
      <div class="flex flex-wrap gap-x-5 gap-y-1.5" aria-label="Experiment catalog status facts">
        {facts.map((fact) => <span class="eyebrow">{fact}</span>)}
      </div>
    </div>
    <p class="border-l border-surface-border pl-4 text-sm leading-relaxed text-muted lg:self-end">
      {SUPPORT}
    </p>
  </section>

  <!-- Per-project blocks -->
  <section>
    {
      cards.map(({ project, experimentCount, focusAreas }) => (
        <article class="grid gap-4 border-b border-surface-border py-9 md:grid-cols-[minmax(0,8rem)_minmax(0,1fr)] md:gap-10">
          <div class="flex flex-row flex-wrap gap-x-4 gap-y-1 md:flex-col md:gap-2">
            <span class="eyebrow">{project.layer}</span>
            <span class="eyebrow text-go-green-dark">{experimentCount} experiments</span>
            <span class="eyebrow text-faint">{focusAreas} focus areas</span>
          </div>

          <div class="grid gap-3">
            <h2 class="text-[1.4rem] font-semibold leading-tight tracking-[-0.01em] md:text-[1.7rem]">
              <a href={`${EXPERIMENTS_PATH}/${project.id}`} class="transition-colors hover:text-go-green-dark">
                {project.title}
              </a>
            </h2>
            <p class="max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{project.summary}</p>
            <p class="text-[0.97rem] font-semibold text-ink">{project.result}</p>

            <ul class="mt-1 grid gap-2">
              {project.evidence.map((item) => (
                <li class="grid grid-cols-[0.9rem_minmax(0,1fr)] gap-2 text-[0.92rem] leading-normal text-muted">
                  <span class="font-mono text-go-green-dark" aria-hidden="true">&mdash;</span>
                  <span class="max-w-[44rem]">{item}</span>
                </li>
              ))}
            </ul>

            <div class="mt-3 flex flex-wrap items-center gap-x-7 gap-y-3">
              <a href={`${EXPERIMENTS_PATH}/${project.id}`} class="cta group text-go-green-dark hover:text-ink">
                View experiments
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
              <a href={decisionProjectPath(project.id)} class="cta group text-ink hover:text-go-green-dark">
                Project decisions
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
              <a href={project.path} class="cta text-ink hover:text-go-green-dark">Project overview</a>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
