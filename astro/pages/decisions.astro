---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getDecisionDomains,
  getDecisionProjectSummary,
  getDecisionRecordsByProject,
} from "../../src/features/site/decision-content";
import {
  getProjectById,
  projectPortfolioContent,
} from "../../src/features/site/projects-content";

// Swiss-minimal redesign — Decisions index (ADR-0005 / #21). Flush-left header +
// hairline right-rail note; per-project hairline editorial blocks with status
// counts as tone-colored mono labels. Presentation only — data reused unchanged.
const PAGE_TITLE = "Decisions | Tony Lee";
const LEDE =
  "Project-level calls that separate serving architecture from kernel optimization evidence.";
const SUPPORT =
  "Choose a project decision page for the status dashboard, grouped decision matrix, related experiments, and next evidence needed.";

// Mirrors getStatusCounts() in the React page: fixed order, drop zero counts.
const STATUS_ORDER = ["Supported", "Measured", "Caveated", "Partial", "Rejected", "Blocked"];
const STATUS_COLOR: Record<string, string> = {
  Supported: "#006b40",
  Measured: "#006b40",
  Caveated: "#8a4413",
  Partial: "#276f89",
  Rejected: "#b3261e",
  Blocked: "#8a4413",
};
const statusCounts = (decisions: ReturnType<typeof getDecisionRecordsByProject>) =>
  STATUS_ORDER.map((status) => ({
    status,
    count: decisions.filter((d) => d.status === status).length,
  })).filter((item) => item.count > 0);
const statusLabel = (status: string) => `color:${STATUS_COLOR[status] ?? "#5c6670"}`;

const cards = projectPortfolioContent.projects.map((p) => {
  const project = getProjectById(p.id);
  const summary = getDecisionProjectSummary(p.id);
  const decisions = getDecisionRecordsByProject(p.id);
  const domains = getDecisionDomains(p.id);
  return { project, summary, decisions, domains };
});
---

<BaseLayout
  title={PAGE_TITLE}
  description={LEDE}
  activeNav="decisions"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Decisions" }]}
>
  <!-- Index header -->
  <section
    class="grid gap-6 border-b border-surface-border pb-10 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(17rem,0.5fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.02] tracking-[-0.02em] text-[clamp(2rem,5vw,3.25rem)]">
        Decisions
      </h1>
      <p class="text-[1.05rem] leading-relaxed text-muted md:text-[1.15rem]">{LEDE}</p>
    </div>
    <p class="border-l border-surface-border pl-4 text-sm leading-relaxed text-muted lg:self-end">
      {SUPPORT}
    </p>
  </section>

  <!-- Per-project decision blocks -->
  <section>
    {
      cards.map(({ project, summary, decisions, domains }) => (
        <article class="grid gap-4 border-b border-surface-border py-9 md:grid-cols-[minmax(0,8rem)_minmax(0,1fr)] md:gap-10">
          <div class="flex flex-row flex-wrap gap-x-4 gap-y-1 md:flex-col md:gap-2">
            <span class="eyebrow">{project.layer}</span>
            <span class="eyebrow text-go-green-dark">{summary.sectionTitle}</span>
            <span class="eyebrow text-faint">{decisions.length} decisions</span>
          </div>

          <div class="grid gap-3">
            <h2 class="text-[1.4rem] font-semibold leading-tight tracking-[-0.01em] md:text-[1.7rem]">
              <a href={summary.path} class="transition-colors hover:text-go-green-dark">
                {project.title}
              </a>
            </h2>
            <p class="max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{summary.lead}</p>
            <p class="text-[0.97rem] font-semibold text-ink">Domains: {domains.join(", ")}.</p>

            <div
              class="mt-1 flex flex-wrap gap-x-5 gap-y-1.5"
              aria-label={`${project.title} decision status counts`}
            >
              {statusCounts(decisions).map((item) => (
                <span
                  class="font-mono text-[0.7rem] font-semibold uppercase tracking-[0.1em]"
                  style={statusLabel(item.status)}
                >
                  {item.count} {item.status.toLowerCase()}
                </span>
              ))}
            </div>

            <div class="mt-3 flex flex-wrap items-center gap-x-7 gap-y-3">
              <a href={summary.path} class="cta group text-go-green-dark hover:text-ink">
                View decisions
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
              <a href={summary.experimentsPath} class="cta group text-ink hover:text-go-green-dark">
                Experiments
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
              <a href={project.path} class="cta text-ink hover:text-go-green-dark">Project overview</a>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
