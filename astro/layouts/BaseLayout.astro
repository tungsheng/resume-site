---
import "../styles/global.css";

type NavKey = "home" | "projects" | "experiments" | "decisions" | "blog" | "resume";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  activeNav?: NavKey;
  breadcrumbs?: Crumb[];
  // Per-page SEO head (#8). Defaults keep non-article pages as og:type=website
  // with no article:* tags. blog/[slug].astro passes ogType="article" + dates.
  ogType?: "website" | "article";
  image?: string; // root-relative or absolute; absolutized against Astro.site
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  section?: string;
}

const {
  title,
  description,
  activeNav,
  breadcrumbs = [],
  ogType = "website",
  image,
  publishedTime,
  modifiedTime,
  tags = [],
  section,
} = Astro.props;

const SITE_NAME = "Tony Lee";

// Canonical paths mirror src/features/site/content.ts.
const navItems: { key: NavKey; label: string; href: string }[] = [
  { key: "home", label: "Home", href: "/" },
  { key: "projects", label: "Projects", href: "/projects" },
  { key: "experiments", label: "Experiments", href: "/experiments" },
  { key: "decisions", label: "Decisions", href: "/decisions" },
  { key: "blog", label: "Blog", href: "/blog" },
  { key: "resume", label: "Resume", href: "/resume" },
];

function navLinkClass(key: NavKey): string {
  const base = "rounded-md px-3 py-1.5 text-sm font-medium transition-colors";
  return key === activeNav
    ? base + " bg-go-green/10 text-ink font-semibold"
    : base + " text-muted hover:bg-ink/5 hover:text-ink";
}

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : undefined;
const isArticle = ogType === "article";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph + Twitter card (#8). article:* only on og:type=article. */}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {
      isArticle && publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )
    }
    {
      isArticle && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime.toISOString()} />
      )
    }
    {isArticle && section && <meta property="article:section" content={section} />}
    {isArticle && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body class="flex min-h-screen flex-col font-sans text-ink">
    <header class="sticky top-0 z-10 border-b border-surface-border bg-paper">
      <div class="mx-auto flex w-full max-w-5xl items-center gap-3 px-4 py-2 md:py-3">
        <a
          href="/"
          aria-label="Tony Lee home"
          class="mr-auto inline-flex h-10 w-10 items-center justify-center font-mono text-lg font-bold"
        >
          TL
        </a>

        <!-- Desktop nav -->
        <nav aria-label="Primary" class="hidden sm:block">
          <ul class="flex flex-wrap justify-end gap-1">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={navLinkClass(item.key)}
                    aria-current={item.key === activeNav ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- Mobile nav: CSS-only <details>/<summary>, zero JavaScript (ADR-0003 §7) -->
        <details class="relative sm:hidden">
          <summary
            class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md hover:bg-ink/5 [&::-webkit-details-marker]:hidden"
            aria-label="Toggle navigation menu"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </summary>
          <nav
            aria-label="Primary"
            class="absolute right-0 mt-2 grid w-48 grid-cols-1 gap-1 rounded-md border border-surface-border bg-paper p-2 shadow-sm"
          >
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class={navLinkClass(item.key) + " text-center"}
                  aria-current={item.key === activeNav ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </details>
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8 md:py-10">
      {
        breadcrumbs.length > 0 && (
          <nav aria-label="Breadcrumb" class="mb-4 text-[0.86rem] md:mb-5">
            <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-muted">
              {breadcrumbs.map((crumb, i) => {
                const isCurrent = i === breadcrumbs.length - 1 || !crumb.href;
                return (
                  <li class="flex items-center gap-x-1.5">
                    {i > 0 && <span aria-hidden="true">/</span>}
                    {isCurrent ? (
                      <span aria-current="page" class="font-bold text-ink">
                        {crumb.label}
                      </span>
                    ) : (
                      <a href={crumb.href} class="font-semibold hover:underline">
                        {crumb.label}
                      </a>
                    )}
                  </li>
                );
              })}
            </ol>
          </nav>
        )
      }
      <slot />
    </main>

    <footer class="border-t border-surface-border">
      <div
        class="mx-auto flex w-full max-w-5xl flex-col items-center justify-center gap-1 px-4 py-6 text-center sm:flex-row sm:gap-2"
      >
        <span class="text-sm font-semibold text-ink">Tony Lee</span>
        <span class="hidden text-surface-border sm:inline" aria-hidden="true">|</span>
        <span class="text-sm text-muted">ML Inference Performance Engineering</span>
      </div>
    </footer>
  </body>
</html>
