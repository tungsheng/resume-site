---
import "../styles/global.css";

type NavKey = "home" | "work" | "blog" | "resume";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  activeNav?: NavKey;
  breadcrumbs?: Crumb[];
  // Per-page SEO head (#8). Defaults keep non-article pages as og:type=website
  // with no article:* tags. blog/[slug].astro passes ogType="article" + dates.
  ogType?: "website" | "article";
  image?: string; // root-relative or absolute; absolutized against Astro.site
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  section?: string;
  // Link the self-hosted KaTeX stylesheet (#33 / ADR-0006). Off by default so
  // non-math pages stay CSS-clean; blog/[slug].astro sets it only when the Post
  // source carries math (detected pre-render). Fonts are browser-lazy, so only a
  // real math page fetches the WOFF2.
  mathStylesheet?: boolean;
}

const {
  title,
  description,
  activeNav,
  breadcrumbs = [],
  ogType = "website",
  image,
  publishedTime,
  modifiedTime,
  tags = [],
  section,
  mathStylesheet = false,
} = Astro.props;

const SITE_NAME = "Tony Lee";

const navItems: { key: NavKey; label: string; href: string }[] = [
  { key: "home", label: "Home", href: "/" },
  { key: "work", label: "Work", href: "/work" },
  { key: "blog", label: "Blog", href: "/blog" },
  { key: "resume", label: "Resume", href: "/resume" },
];

function isNavActive(key: NavKey): boolean {
  return key === activeNav;
}

// Editorial mono nav (#55): title-case IBM Plex Mono links; the active item is
// marked by ink color + a 1.5px go-green underline, inactive is muted with a
// transparent underline that resolves to ink on hover.
function navLinkClass(key: NavKey): string {
  const base =
    "font-mono text-[0.78rem] tracking-[0.03em] pb-1 border-b-[1.5px] transition-colors";
  return isNavActive(key)
    ? base + " border-go-green text-ink"
    : base + " border-transparent text-muted hover:text-ink";
}

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : undefined;
const isArticle = ogType === "article";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph + Twitter card (#8). article:* only on og:type=article. */}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {
      isArticle && publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )
    }
    {
      isArticle && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime.toISOString()} />
      )
    }
    {isArticle && section && <meta property="article:section" content={section} />}
    {isArticle && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* Self-hosted KaTeX styles, linked only on math Posts (#33 / ADR-0006).
        CSP-clean: the inline span styles ride style-src 'unsafe-inline' and the
        WOFF2 fonts satisfy font-src 'self'. The CSS references fonts/ relatively,
        so it sits alongside its fonts under /katex/. */}
    {mathStylesheet && <link rel="stylesheet" href="/katex/katex.min.css" />}
  </head>
  <body class="flex min-h-screen flex-col font-sans text-ink antialiased">
    <header class="sticky top-0 z-20 border-b border-surface-border bg-paper">
      <div class="mx-auto flex w-full max-w-[880px] items-baseline justify-between px-5 py-5 sm:px-7">
        <!-- Brand: the "TL." editorial wordmark — Newsreader semibold ink glyphs
             with an accent-colored period. -->
        <a
          href="/"
          aria-label="Tony Lee home"
          class="font-sans text-[1.31rem] font-semibold leading-none tracking-[-0.01em] text-ink"
        >
          TL<span class="text-go-green" aria-hidden="true">.</span>
        </a>

        <!-- Desktop nav -->
        <nav aria-label="Primary" class="hidden sm:block">
          <ul class="flex flex-wrap items-center justify-end gap-x-7 gap-y-2">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={navLinkClass(item.key)}
                    aria-current={item.key === activeNav ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- Mobile nav: CSS-only <details>/<summary>, zero JavaScript (ADR-0003 §7) -->
        <details class="relative sm:hidden">
          <summary
            class="flex h-9 w-9 cursor-pointer list-none items-center justify-center text-ink [&::-webkit-details-marker]:hidden"
            aria-label="Toggle navigation menu"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </summary>
          <nav
            aria-label="Primary"
            class="absolute right-0 mt-3 grid w-52 grid-cols-1 gap-3 border border-surface-border bg-paper p-4"
          >
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class={navLinkClass(item.key) + " border-b-0 pb-0"}
                  aria-current={item.key === activeNav ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </details>
      </div>
    </header>

    <main class="mx-auto w-full max-w-[880px] flex-1 px-5 pb-20 pt-8 sm:px-7">
      {
        breadcrumbs.length > 0 && (
          <nav
            aria-label="Breadcrumb"
            class="mb-6 font-mono text-[0.75rem] tracking-[0.02em] md:mb-8"
          >
            <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-muted">
              {breadcrumbs.map((crumb, i) => {
                const isCurrent = i === breadcrumbs.length - 1 || !crumb.href;
                return (
                  <li class="flex items-center gap-x-2">
                    {i > 0 && <span aria-hidden="true" class="text-go-green">/</span>}
                    {isCurrent ? (
                      <span aria-current="page" class="text-ink">
                        {crumb.label}
                      </span>
                    ) : (
                      <a href={crumb.href} class="hover:text-ink">
                        {crumb.label}
                      </a>
                    )}
                  </li>
                );
              })}
            </ol>
          </nav>
        )
      }
      <slot />
    </main>

    <footer class="border-t border-surface-border">
      <div
        class="mx-auto flex w-full max-w-[880px] flex-wrap items-baseline justify-between gap-x-6 gap-y-3 px-5 py-7 sm:px-7"
      >
        <div class="flex flex-col gap-1">
          <span class="font-sans text-[1rem] font-semibold text-ink">Tony Lee</span>
          <span class="font-mono text-[0.72rem] tracking-[0.02em] text-muted"
            >Staff Software Engineer · ML Inference</span
          >
        </div>
        <a
          href="https://linkedin.com/in/tonyslee8"
          target="_blank"
          rel="noreferrer"
          class="font-mono text-[0.72rem] tracking-[0.02em] text-muted transition-colors hover:text-ink"
        >
          LinkedIn &rarr;
        </a>
      </div>
    </footer>
  </body>
</html>
