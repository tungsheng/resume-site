---
import type { PostListItem } from "../content/post-list";
import { isRegisteredTag, tagLabel, tagPath } from "../content/tag-registry";

// Editorial Post list (#58), shared by the /blog index and the /blog/tags/[tag]
// pages (#48) so both render Posts identically. Each post is one stacked link:
// a mono meta row (category · date · reading time) over a Newsreader title and
// the summary, with the whole card resolving to the accent on hover. Reading
// time (post.minutes) is computed from word count in the post-list module, so
// new posts self-populate. Registered tag chips (ADR-0009) sit in a mono row
// below the card — outside the card link, since they are their own links.

interface Props {
  posts: PostListItem[];
}

const { posts } = Astro.props;
---

<section>
  {
    posts.map((post) => {
      const tags = (post.data.tags ?? []).filter(isRegisteredTag);
      return (
        <article class="group border-t border-surface-border last:border-b">
          <a href={`/blog/${post.slug}`} class="flex flex-col gap-2 pt-8 pb-3">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[0.72rem] uppercase tracking-[0.08em]">
              {import.meta.env.DEV && post.data.status !== "Published" && (
                <span class="rounded-sm border border-warning-warm/40 bg-warning-soft px-1.5 py-px text-warning-warm">
                  {post.data.status}
                </span>
              )}
              <span class="text-go-green-dark">{post.data.category}</span>
              <time datetime={post.iso} class="tabular text-faint">
                {post.iso}
              </time>
              <span class="text-faint">{post.minutes} min</span>
            </div>
            <h2 class="text-[1.875rem] font-medium leading-[1.2] tracking-[-0.015em] text-ink transition-colors group-hover:text-go-green-dark">
              {post.data.title}
            </h2>
            <p class="max-w-[640px] text-[1rem] leading-[1.6] text-secondary">{post.data.summary}</p>
          </a>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-x-4 gap-y-1 pb-8 font-mono text-[0.7rem] uppercase tracking-[0.08em]">
              {tags.map((tag) => (
                <a href={tagPath(tag)} class="text-faint transition-colors hover:text-go-green-dark">
                  {tagLabel(tag)}
                </a>
              ))}
            </div>
          )}
        </article>
      );
    })
  }
</section>
