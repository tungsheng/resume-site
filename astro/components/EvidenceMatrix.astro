---
// Swiss-minimal port of TwoMetricEvidenceMatrix (ADR-0005 / #21): a titled cell
// with a takeaway and rows of two labeled horizontal bars (sharp, hairline-
// separated). Rendered inside the parent's hairline grid, so the root is a plain
// bg-paper cell rather than its own bordered card. Zero JS.
interface Cell {
  value: number;
  label: string;
  tone?: string;
}
interface Column {
  key: string;
  label: string;
  max: number;
  tone?: string;
}
interface Row {
  label: string;
  context?: string;
  values: Record<string, Cell>;
}
interface Props {
  title: string;
  takeaway: string;
  sourceLabel?: string;
  columns: Column[];
  rows: Row[];
}
const { title, takeaway, sourceLabel, columns, rows } = Astro.props;

const TONE: Record<string, string> = {
  success: "#006b40",
  info: "#276f89",
  warning: "#8a4413",
  error: "#b3261e",
  neutral: "#8b939c",
};
const toneColor = (tone = "neutral") => TONE[tone] ?? TONE.neutral;
const barWidth = (value: number, max: number) =>
  max <= 0 || value <= 0 ? "0%" : `${Math.min(100, Math.max(4, (value / max) * 100))}%`;
---

<section class="grid content-start gap-3 bg-paper p-4">
  <div class="grid gap-1">
    <h3 class="text-[1.02rem] font-semibold text-ink">{title}</h3>
    <p class="text-[0.92rem] leading-relaxed text-muted">{takeaway}</p>
  </div>

  <div class="grid gap-2.5">
    {
      rows.map((row) => (
        <div class="grid items-baseline gap-2 border-t border-surface-border pt-2.5 first:border-t-0 first:pt-0 md:grid-cols-[minmax(9rem,0.7fr)_repeat(2,minmax(8rem,1fr))] md:gap-4">
          <div class="grid min-w-0 gap-0.5">
            <p class="text-[0.88rem] font-bold text-ink">{row.label}</p>
            {row.context && <p class="text-[0.78rem] text-muted">{row.context}</p>}
          </div>
          {
            columns.map((column) => {
              const cell = row.values[column.key];
              if (!cell) return null;
              return (
                <div class="grid min-w-0 gap-1">
                  <div class="flex items-baseline justify-between gap-2">
                    <span class="eyebrow">{column.label}</span>
                    <span class="text-[0.78rem] font-bold tabular text-ink" style="overflow-wrap:anywhere">{cell.label}</span>
                  </div>
                  <div class="relative h-[0.4rem] w-full overflow-hidden bg-surface-border">
                    <div
                      class="h-full"
                      style={`width:${barWidth(cell.value, column.max)};background-color:${toneColor(cell.tone ?? column.tone)}`}
                    >
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      ))
    }
  </div>

  {sourceLabel && <p class="text-[0.78rem] text-muted">{sourceLabel}</p>}
</section>
