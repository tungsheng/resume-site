---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  EXPERIMENTS_PATH,
  experimentCatalogContent,
  experimentDetailPath,
  decisionProjectPath,
  getProjectById,
  type ProjectId,
} from "@site";

// Swiss-minimal redesign — experiment catalog (/experiments/<projectId>),
// ADR-0005 / #21. The browse table becomes a hairline table (horizontal rules,
// mono column headers, tone-colored status lines). Presentation only.
interface Props {
  projectId: ProjectId;
}
const { projectId } = Astro.props;
const project = getProjectById(projectId);
const { experiments } = experimentCatalogContent;
const selected = experiments.filter((e) => e.projectId === projectId);
const catalogTitle =
  projectId === "gpu-inference-lab"
    ? "GPU Inference Lab Experiments"
    : `${project.title} Experiments`;

const countTone = (tone: string) =>
  experiments.filter((e) => e.readiness.primary.tone === tone).length;
const projectCount = new Set(experiments.map((e) => e.projectId)).size;
const facts = [
  `${experiments.length} experiments`,
  `${projectCount} projects`,
  "Run-ready",
  `${countTone("supported")} supported`,
  `${countTone("selected")} selected`,
  `${countTone("rejected")} rejected`,
  `${countTone("pending")} pending`,
  `${countTone("blocked")} blocked`,
];

const READINESS_COLOR: Record<string, string> = {
  supported: "#006b40",
  selected: "#276f89",
  rejected: "#b3261e",
  pending: "#8a4413",
  blocked: "#8a4413",
};
const readinessColor = (tone: string) => READINESS_COLOR[tone] ?? "#006b40";

const fieldLabel = "eyebrow mb-1 md:hidden";
const rowCols = "md:grid-cols-[minmax(14rem,1fr)_minmax(11rem,0.75fr)_minmax(12rem,1fr)_minmax(11rem,0.85fr)_8rem]";
---

<BaseLayout
  title={`${project.title} Experiments | Tony Lee`}
  description={experimentCatalogContent.subtitle}
  activeNav="experiments"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Work", href: "/work" },
    { label: "Experiments", href: EXPERIMENTS_PATH },
    { label: project.title },
  ]}
>
  <!-- Header -->
  <section
    class="grid gap-6 border-b border-surface-border pb-9 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(16rem,0.46fr)] lg:gap-12"
  >
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.04] tracking-[-0.02em] text-[clamp(1.9rem,4.5vw,3rem)]">
        {catalogTitle}
      </h1>
      <p class="text-[1.02rem] leading-relaxed text-muted md:text-[1.12rem]">
        {experimentCatalogContent.subtitle}
      </p>
      <div class="flex flex-wrap gap-x-5 gap-y-1.5" aria-label="Experiment catalog status facts">
        {facts.map((fact) => <span class="eyebrow">{fact}</span>)}
      </div>
    </div>
    <div class="flex flex-col gap-2 border-l border-surface-border pl-5 lg:self-end" role="note">
      <span class="eyebrow text-go-green-dark">Catalog ready</span>
      <p class="text-[0.92rem] leading-relaxed text-muted">{experimentCatalogContent.statusNote}</p>
      <a href={decisionProjectPath(projectId)} class="cta group mt-1 text-ink hover:text-go-green-dark">
        Project decisions
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- Browse table -->
  <section class="mt-10 md:mt-12">
    <div
      class={`hidden gap-5 border-b border-ink/15 pb-2.5 md:grid ${rowCols}`}
      aria-hidden="true"
    >
      {["Experiment", "Purpose", "Focus", "Status", "Details"].map((h) => (
        <span class="eyebrow">{h}</span>
      ))}
    </div>

    {
      selected.map((exp) => {
        const signals = [exp.readiness.primary, ...(exp.readiness.secondary ? [exp.readiness.secondary] : [])];
        return (
          <section class={`grid gap-3 border-b border-surface-border py-5 md:items-baseline md:gap-5 ${rowCols}`}>
            <div class="min-w-0">
              <span class={fieldLabel}>Experiment</span>
              <p class="eyebrow mb-1">{exp.category}</p>
              <p class="text-[0.95rem] font-semibold text-ink">{exp.title}</p>
            </div>

            <div class="min-w-0">
              <span class={fieldLabel}>Purpose</span>
              <p class="text-[0.92rem] leading-relaxed text-muted">{exp.cardSummary}</p>
            </div>

            <div class="min-w-0">
              <span class={fieldLabel}>Focus</span>
              <div class="flex flex-wrap gap-x-3 gap-y-1">
                {exp.metricFocus.map((m) => <span class="eyebrow text-go-green-dark">{m}</span>)}
              </div>
            </div>

            <div class="min-w-0">
              <span class={fieldLabel}>Status</span>
              <div class="grid max-w-[14rem] gap-1" aria-label={`${exp.title} status`}>
                <span class="font-mono text-[0.72rem] font-semibold uppercase tracking-[0.08em]" style="color:#006b40">
                  Run ready
                </span>
                {signals.map((sig) => (
                  <span
                    class="font-mono text-[0.72rem] font-semibold uppercase tracking-[0.08em] leading-snug"
                    style={`color:${readinessColor(sig.tone)}`}
                  >
                    {sig.label}
                    <span class="text-faint"> &middot; {sig.detail}</span>
                  </span>
                ))}
              </div>
            </div>

            <div class="min-w-0 md:justify-self-end">
              <span class={fieldLabel}>Details</span>
              <a href={experimentDetailPath(exp.slug)} class="cta group text-ink hover:text-go-green-dark">
                Details
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>
          </section>
        );
      })
    }

    {
      projectId === "gpu-inference-lab" && (
        <section class="mt-8 grid items-baseline gap-3 border-t border-surface-border pt-8 md:grid-cols-[minmax(0,1fr)_auto]">
          <div class="grid min-w-0 gap-1">
            <p class="eyebrow">{experimentCatalogContent.platformValidation.status}</p>
            <p class="text-[0.97rem] font-semibold text-ink">Decisions live in the project decision record</p>
            <p class="text-[0.92rem] leading-relaxed text-muted">
              {experimentCatalogContent.platformValidation.question}
            </p>
          </div>
          <a href={experimentCatalogContent.platformValidation.href} class="cta group text-ink hover:text-go-green-dark">
            Project decisions
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </section>
      )
    }
  </section>
</BaseLayout>
