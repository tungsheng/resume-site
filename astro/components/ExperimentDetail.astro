---
import BaseLayout from "../layouts/BaseLayout.astro";
import CommandCodeBlock from "./CommandCodeBlock.astro";
import {
  EXPERIMENTS_PATH,
  experimentSourceLink,
  type ExperimentCatalogItem,
  decisionProjectPath,
  getDecisionRecordsByExperimentSlug,
  getProjectById,
} from "@site";

// Detail view (/experiments/<slug>) — faithful port of ExperimentDetailRoute.
// Rendered by experiments/[entry].astro when the segment is an experiment slug.
interface Props {
  experiment: ExperimentCatalogItem;
}
const { experiment } = Astro.props;
const project = getProjectById(experiment.projectId);
const catalogPath = `${EXPERIMENTS_PATH}/${project.id}`;

// ---- helpers (ported from src/features/experiments/page.tsx) ----
function formatCount(value: number, singular: string, plural = `${singular}s`): string {
  return `${value} ${value === 1 ? singular : plural}`;
}
function formatTokenRange(values: number[]): string {
  const min = Math.min(...values);
  const max = Math.max(...values);
  return min === max
    ? min.toLocaleString("en-US")
    : `${min.toLocaleString("en-US")}-${max.toLocaleString("en-US")}`;
}
function formatRunShapeCopy(e: ExperimentCatalogItem): string {
  if (e.runShapeSummary) return e.runShapeSummary;
  const pt = e.cases.map((c) => c.promptTokens).filter((v): v is number => typeof v === "number");
  const ot = e.cases.map((c) => c.outputTokens).filter((v): v is number => typeof v === "number");
  if (pt.length === e.cases.length && ot.length === e.cases.length) {
    return `${formatCount(e.cases.length, "case")} across ${formatTokenRange(pt)} prompt tokens and ${formatTokenRange(ot)} output tokens, paired with ${formatCount(e.servingProfiles.length, "run profile")}.`;
  }
  return `${formatCount(e.cases.length, "case")} paired with ${formatCount(e.servingProfiles.length, "run profile")}.`;
}
function caseMeasureLabels(item: ExperimentCatalogItem["cases"][number]): string[] {
  const labels: string[] = [];
  if (item.primaryMeasure) labels.push(item.primaryMeasure);
  else if (typeof item.promptTokens === "number") labels.push(`${item.promptTokens.toLocaleString("en-US")} prompt tokens`);
  if (item.secondaryMeasure) labels.push(item.secondaryMeasure);
  else if (typeof item.outputTokens === "number") labels.push(`${item.outputTokens.toLocaleString("en-US")} output tokens`);
  return labels;
}
function reportRulesPath(e: ExperimentCatalogItem): string {
  return e.projectId === "cuda-kernel-lab" ? "docs/optimization-strategies.md" : "docs/reports/README.md";
}

const RT_KEYS = ["target", "outcome", "p95Latency", "peakWaiting", "gpuMax"] as const;
const RT_DEFAULT = { target: "Target", outcome: "Outcome", p95Latency: "p95 latency", peakWaiting: "Peak waiting", gpuMax: "GPU max" };
const evidence = experiment.resultEvidence;
const tables = evidence
  ? evidence.tables && evidence.tables.length > 0
    ? evidence.tables
    : evidence.rows && evidence.rows.length > 0
      ? [{ title: `${evidence.title} table`, columns: evidence.tableColumns, rows: evidence.rows }]
      : []
  : [];

const READINESS_HEX: Record<string, string> = {
  supported: "#006b40",
  selected: "#276f89",
  rejected: "#b3261e",
  pending: "#8a4413",
  blocked: "#8a4413",
};
const toneStyle = (tone: string) => `color:${READINESS_HEX[tone] ?? "#5c6670"}`;

const primary = experiment.readiness.primary;
const secondary = experiment.readiness.secondary;
const isBlocked = primary.tone === "blocked";
const blockedTitle = experiment.projectId === "gpu-inference-lab" ? "Blackwell capacity blocked" : `${primary.detail} blocked`;
const blockedCopy = experiment.projectId === "gpu-inference-lab"
  ? "Blackwell capacity blocked the live run. Store generated Markdown, JSON, and client logs in docs/reports/ until a comparable result is selected."
  : `${primary.detail} blocked this proof. Store compact profiler notes with the project until comparable counters are selected.`;
const pendingCopy = isBlocked
  ? blockedCopy
  : `${experiment.resultsPath} is still a template. Store generated Markdown, JSON, and client logs in docs/reports/ until a representative run is selected.`;
const resultLinkLabel = evidence?.curatedResults === false ? "Results template" : evidence ? "Results summary" : "Results template";

const relatedDecisions = getDecisionRecordsByExperimentSlug(experiment.slug);
const localCommand = experiment.localCommands[0];
const liveCommand = experiment.liveCommands[0];

const summaryFacts = [
  { label: "Project", value: project.title },
  { label: "Focus", value: experiment.category },
  { label: "Run shape", value: `${formatCount(experiment.cases.length, "case")} / ${formatCount(experiment.servingProfiles.length, "profile")}` },
  {
    label: "Evidence",
    value: [
      `${primary.label}: ${primary.detail}`,
      secondary ? `${secondary.label}: ${secondary.detail}` : null,
    ].filter(Boolean).join(" / "),
  },
];

// Swiss idioms (ADR-0005 / #21): hairline spec-sheet grids, hairline-left accent/
// warning blocks, tone-colored mono labels, .cta links.
const grid = "grid gap-px border border-surface-border bg-surface-border";
const cell = "bg-paper p-4 grid content-start";
const accentBlock = "border-l-2 border-l-go-green pl-4";
const warnBlock = "border-l-2 border-l-warning-warm/70 pl-4";
const tableCols = "md:grid-cols-[minmax(7rem,0.9fr)_minmax(10rem,1fr)_repeat(3,minmax(5.5rem,0.7fr))]";
---

<BaseLayout
  title={`${experiment.title} | Tony Lee`}
  description={experiment.summary}
  activeNav="experiments"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Work", href: "/work" },
    { label: "Experiments", href: EXPERIMENTS_PATH },
    { label: project.title, href: catalogPath },
    { label: experiment.title },
  ]}
>
  <!-- Header -->
  <section class="grid gap-6 border-b border-surface-border pb-9 md:pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(16rem,0.46fr)] lg:gap-12">
    <div class="flex max-w-[52rem] flex-col gap-5">
      <h1 class="text-balance font-semibold leading-[1.04] tracking-[-0.02em] text-[clamp(1.9rem,4.5vw,3rem)]">{experiment.title}</h1>
      <p class="text-[1.02rem] leading-relaxed text-muted md:text-[1.12rem]">{experiment.question}</p>
      <div class="mt-1 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href={catalogPath} class="cta group text-go-green-dark hover:text-ink">
          <span aria-hidden="true" class="transition-transform group-hover:-translate-x-1">&larr;</span>
          Experiment catalog
        </a>
        <a href={experimentSourceLink(experiment.projectId, experiment.sourcePath)} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">Source</a>
      </div>
    </div>
    <div class={`${grid} grid-cols-1 sm:grid-cols-2`} aria-label={`${experiment.title} summary facts`}>
      {
        summaryFacts.map((f) => (
          <div class={`${cell} gap-1`}>
            <p class="eyebrow">{f.label}</p>
            <p class="text-[0.9rem] font-semibold text-ink" style="overflow-wrap:anywhere">{f.value}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Why it matters -->
  <section class="mt-12 md:mt-16">
    <h2 class="h-section-title">Why it matters</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{experiment.summary}</p>
    <div class={`mt-5 ${accentBlock}`}>
      <p class="max-w-[48rem] leading-relaxed text-ink">{experiment.whyItMatters}</p>
    </div>
  </section>

  <!-- Result -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2" style={toneStyle(primary.tone)}>{primary.label}</p>
    <h2 class="h-section-title">{evidence ? "Result evidence" : "Result status"}</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">
      {evidence
        ? "Selected live-cluster runs, readiness state, and evidence boundary are shown together."
        : isBlocked
          ? "Definition is ready; the live attempt stopped before a comparable result."
          : "Artifacts stay separate from conclusions until a run is selected."}
    </p>

    {
      evidence ? (
        <div class="mt-5 grid gap-6">
          <div class="flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-[0.72rem] font-semibold uppercase tracking-[0.08em]">
            <span style={toneStyle(primary.tone)}>{primary.label}: {primary.detail}</span>
            <span class="text-go-green-dark">Latest reports: {evidence.reportDate}</span>
            {secondary && <span style={toneStyle(secondary.tone)}>{secondary.label}: {secondary.detail}</span>}
          </div>

          <div class="grid gap-1.5">
            <h3 class="text-[1.05rem] font-semibold text-ink">{evidence.title}</h3>
            <p class="max-w-[48rem] text-[0.92rem] leading-relaxed text-muted">{evidence.summary}</p>
          </div>

          <div class={`${grid} md:grid-cols-3`} aria-label={`${experiment.title} measured result highlights`}>
            {
              evidence.stats.map((stat) => (
                <div class={`${cell} gap-1`}>
                  <p class="eyebrow">{stat.label}</p>
                  <p class="text-[1.05rem] font-semibold tabular text-ink" style="overflow-wrap:anywhere">{stat.value}</p>
                  <p class="text-[0.85rem] leading-relaxed text-muted">{stat.context}</p>
                </div>
              ))
            }
          </div>

          {
            tables.map((table) => {
              const cols = { ...RT_DEFAULT, ...(table.columns ?? {}) };
              return (
                <div>
                  <p class="text-[0.97rem] font-semibold text-ink">{table.title}</p>
                  {table.summary && <p class="text-[0.92rem] leading-relaxed text-muted">{table.summary}</p>}
                  <div class="mt-2.5" role="table" aria-label={`${experiment.title} ${table.title}`}>
                    <div class={`hidden gap-3 border-b border-ink/15 pb-2 md:grid ${tableCols}`} role="row">
                      {RT_KEYS.map((k) => <span class="eyebrow">{cols[k]}</span>)}
                    </div>
                    {table.rows.map((row) => (
                      <div class={`grid gap-1 border-b border-surface-border py-3 md:items-baseline md:gap-3 ${tableCols}`} role="row">
                        {RT_KEYS.map((k, i) => (
                          <p class={`text-[0.92rem] ${i === 0 ? "font-semibold text-ink" : "tabular text-muted"}`} role="cell" style="overflow-wrap:anywhere">
                            <span class="mr-1 font-mono text-[0.64rem] uppercase tracking-wide text-faint md:hidden">{cols[k]}: </span>
                            {row[k]}
                          </p>
                        ))}
                      </div>
                    ))}
                  </div>
                </div>
              );
            })
          }

          <div class={warnBlock}>
            <p class="eyebrow mb-1" style="color:#8a4413">Evidence boundary</p>
            <p class="max-w-[48rem] text-[0.92rem] leading-relaxed text-muted">{evidence.boundary}</p>
            {evidence.boundaryPoints && evidence.boundaryPoints.length > 0 && (
              <ul class="mt-2 grid max-w-[48rem] gap-1.5">
                {evidence.boundaryPoints.map((p) => (
                  <li class="grid grid-cols-[0.9rem_minmax(0,1fr)] gap-2 text-[0.92rem] leading-relaxed text-muted">
                    <span class="font-mono text-faint" aria-hidden="true">&mdash;</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="flex flex-wrap items-center gap-x-7 gap-y-3">
            {(evidence.sourceReports ?? []).map((report) => (
              <a href={experimentSourceLink(experiment.projectId, report.path)} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">{report.label}</a>
            ))}
            <a href={experimentSourceLink(experiment.projectId, experiment.resultsPath)} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">
              {evidence.curatedResults === false ? "Results template" : "Results summary"}
            </a>
            <a href={experimentSourceLink(experiment.projectId, reportRulesPath(experiment))} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">Report rules</a>
          </div>
        </div>
      ) : (
        <div class={`mt-5 ${warnBlock}`}>
          <h3 class="text-[1.05rem] font-semibold text-ink">{isBlocked ? blockedTitle : "Live result pending"}</h3>
          <p class="mt-1 max-w-[48rem] text-[0.92rem] leading-relaxed text-muted">{pendingCopy}</p>
          {experiment.pendingNextRuns && experiment.pendingNextRuns.length > 0 && (
            <div class="mt-4">
              <p class="eyebrow mb-2">Next runs to curate</p>
              <div class={`${grid} lg:grid-cols-2`}>
                {experiment.pendingNextRuns.map((run) => (
                  <div class={`${cell} gap-2`}>
                    <p class="text-[0.97rem] font-semibold text-ink">{run.label}</p>
                    <p class="text-[0.92rem] leading-relaxed text-muted">{run.reason}</p>
                    <CommandCodeBlock command={run.command} ariaLabel={`${run.label} next run command`} />
                  </div>
                ))}
              </div>
            </div>
          )}
          <div class="mt-4 flex flex-wrap items-center gap-x-7 gap-y-3">
            <a href={experimentSourceLink(experiment.projectId, experiment.resultsPath)} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">Results template</a>
            <a href={experimentSourceLink(experiment.projectId, reportRulesPath(experiment))} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">Report rules</a>
          </div>
        </div>
      )
    }
  </section>

  <!-- Related decisions -->
  {
    relatedDecisions.length > 0 && (
      <section class="mt-12 md:mt-16">
        <p class="eyebrow mb-2">Decision links</p>
        <h2 class="h-section-title">Supports decisions</h2>
        <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">
          Decision records own the project conclusions; this experiment supplies evidence for the calls below.
        </p>
        <div class={`${grid} md:grid-cols-2`}>
          {relatedDecisions.map((decision) => (
            <section class={`${cell} gap-2`}>
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
                <span class="eyebrow text-go-green-dark">{decision.status}</span>
                <span class="eyebrow text-faint">{decision.domain}</span>
              </div>
              <h3 class="text-[1.05rem] font-semibold text-ink">{decision.title}</h3>
              <p class="text-[0.92rem] font-bold text-ink">{decision.call}</p>
              <p class="text-[0.92rem] leading-relaxed text-muted">{decision.evidence}</p>
              <a href={decisionProjectPath(decision.projectId)} class="cta group mt-1 justify-self-start text-ink hover:text-go-green-dark">
                Decision record
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
            </section>
          ))}
        </div>
      </section>
    )
  }

  <!-- Run shape -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2">Run shape</p>
    <h2 class="h-section-title">Run shape</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">{formatRunShapeCopy(experiment)}</p>
    <div class="mt-5 grid gap-8 lg:grid-cols-2">
      <div>
        <div class="mb-2 flex flex-wrap items-baseline justify-between gap-2 border-b border-surface-border pb-2">
          <p class="eyebrow">Cases</p>
          <p class="eyebrow text-faint">{formatCount(experiment.cases.length, "case")}</p>
        </div>
        <div class={grid}>
          {
            experiment.cases.map((item) => (
              <div class={`${cell} gap-1.5`}>
                <p class="text-[1.02rem] font-semibold text-ink" style="overflow-wrap:anywhere">{item.id}</p>
                <p class="text-[0.92rem] leading-relaxed text-muted">{item.description}</p>
                <div class="flex flex-wrap gap-x-4 gap-y-1">
                  {caseMeasureLabels(item).map((label) => <span class="eyebrow text-go-green-dark">{label}</span>)}
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div>
        <div class="mb-2 flex flex-wrap items-baseline justify-between gap-2 border-b border-surface-border pb-2">
          <p class="eyebrow">Run profiles</p>
          <p class="eyebrow text-faint">{formatCount(experiment.servingProfiles.length, "profile")}</p>
        </div>
        <div class={grid}>
          {
            experiment.servingProfiles.map((profile) => (
              <div class={`${cell} gap-1.5`}>
                <p class="text-[1.02rem] font-semibold text-ink" style="overflow-wrap:anywhere">{profile.id}</p>
                <p class="text-[0.92rem] leading-relaxed text-muted">{profile.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Metrics -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2">Measurement focus</p>
    <h2 class="h-section-title">Metrics to capture</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">Metric groups show the signal this experiment needs.</p>
    <div class={`${grid} md:grid-cols-3`}>
      {
        experiment.metricGroups.map((group) => (
          <div class={`${cell} gap-2`}>
            <p class="text-[1.02rem] font-semibold text-ink">{group.label}</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1">
              {group.metrics.map((m) => <span class="eyebrow">{m}</span>)}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- How to run -->
  <section class="mt-12 md:mt-16">
    <p class="eyebrow mb-2">Usage</p>
    <h2 class="h-section-title">How to run</h2>
    <p class="mt-2.5 max-w-[46rem] text-[0.97rem] leading-relaxed text-muted">Examples show one local render path and one live-cluster path.</p>
    <div class="mt-5 grid gap-5 md:grid-cols-2">
      <div class="grid content-start gap-2">
        <p class="eyebrow">Example local command</p>
        {localCommand && <CommandCodeBlock command={localCommand} ariaLabel={`${experiment.title} example local command`} />}
      </div>
      <div class="grid content-start gap-2">
        <p class="eyebrow">Example live command</p>
        {liveCommand && <CommandCodeBlock command={liveCommand} ariaLabel={`${experiment.title} example live command`} />}
      </div>
    </div>
    <div class="mt-5 flex flex-wrap items-center gap-x-7 gap-y-3">
      <a href={experimentSourceLink(experiment.projectId, experiment.sourcePath)} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">Source</a>
      <a href={experimentSourceLink(experiment.projectId, experiment.resultsPath)} target="_blank" rel="noreferrer" class="cta link-external text-ink hover:text-go-green-dark">{resultLinkLabel}</a>
    </div>
  </section>
</BaseLayout>
