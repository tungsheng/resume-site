{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Path aliases for the src/ feature modules (decouples call sites from the
    // in-flight srcDir migration; Astro/Vite, tsc, and bun test all honor these).
    "baseUrl": ".",
    "paths": {
      "@site": ["src/features/site/index.ts"],
      "@site/*": ["src/features/site/*"],
      "@resume/*": ["src/features/resume/*"],
      "@services/*": ["src/services/*"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false
  },
  // `.astro/types.d.ts` (generated by `astro sync`) declares the virtual
  // `astro:content` module used by the content collection config/pages.
  "include": ["**/*.ts", "**/*.tsx", ".astro/types.d.ts"]
}
