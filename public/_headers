# Cloudflare Pages response headers (ADR-0003 §3): security headers move off the
# Bun server middleware to this file. Ported from addSecurityHeaders() in the old
# src/index.ts. script-src is 'self' — the search island (#49 / ADR-0008) ships
# only external same-origin scripts, never inline — plus 'wasm-unsafe-eval',
# which Pagefind's WebAssembly search engine requires to instantiate.
# style-src keeps 'unsafe-inline' because Astro may inline small stylesheets.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; font-src 'self'; base-uri 'self'; form-action 'self'

# Astro's bundled assets are content-hashed in the filename (…​.HASH.css/js), so a
# change ships under a new URL — safe to cache immutably. Without this rule they
# fall under /* and CF revalidates them (cf-cache-status: REVALIDATED), leaving
# asset delivery more fragile across a deploy; immutable makes it hermetic.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted blog images (#6) are content-addressed by post slug and effectively
# immutable once published — let the browser cache them aggressively.
/assets/blog/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted web fonts (#55): Newsreader + IBM Plex Mono woff2. Versioned by
# content; cache aggressively.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
